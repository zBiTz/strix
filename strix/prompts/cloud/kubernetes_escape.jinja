<lateral_movement>
<pod_to_pod>
{% raw %}
# Move between pods

# Network scan
nmap -p 1-65535 10.244.0.0/16  # Pod network (example)
nmap -p 1-65535 10.96.0.0/12   # Service network (example)

# Service discovery
nslookup kubernetes.default.svc.cluster.local
nslookup <service-name>.<namespace>.svc.cluster.local

# Access other pods' services
curl http://<pod-ip>:<port>
curl http://<service-name>.<namespace>.svc.cluster.local:<port>

# If network policies allow:
# Try to access services in other namespaces
