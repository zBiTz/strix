# Pod-to-pod direct communication (if no network policy)
curl http://<target-pod-ip>:<port>

# Try common ports:
# 22 (SSH), 80/443 (HTTP), 3306 (MySQL), 5432 (PostgreSQL), 6379 (Redis), 27017 (MongoDB)
{% endraw %}
</pod_to_pod>

