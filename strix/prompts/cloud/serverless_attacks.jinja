<cold_start_attacks>
<timing_exploitation>
{% raw %}
# Cold start vs warm start

# Cold start: First invocation, slow (seconds)
# Warm start: Reuse container, fast (milliseconds)

# Timing attack:

# 1. Measure response time
import time
start = time.time()
response = requests.post(lambda_url, json=payload)
duration = time.time() - start
print(f"Duration: {duration}s")

# Cold start indicators:
# - Longer response time (2-10 seconds)
# - x-amzn-trace-id header different
# - x-amz-executed-version may differ

# 2. Force cold start:
# Wait for timeout (Lambda container recycles after ~15 min inactivity)
# Send request after 15+ min
# Observe longer response time

# 3. Exploit cold start logic:
# Some apps initialize differently on cold start
# Global variables, database connections, etc.
# May bypass security checks during initialization
{% endraw %}
</timing_exploitation>

<resource_exhaustion>
{% raw %}
# Exhaust Lambda resources

# 1. Memory exhaustion:
# Send large payload
POST /api/function
{"data": "A" * 10000000}  # 10 MB

# If Lambda processes into memory, may exceed limit
# Default: 128 MB, Max: 10 GB

# 2. Timeout exploitation:
# Send payload that causes long processing
# Lambda times out (default: 3s, max: 15min)
{"sleep": 900}  # Sleep for 15 minutes

# If timeout, operation incomplete
# May leave inconsistent state

# 3. Concurrent execution exhaustion:
# Send many requests simultaneously
# Exhaust concurrent execution limit (default: 1000)
for i in range(10000):
    requests.post(lambda_url, json=payload)

# Result: Throttling errors
# {"errorMessage": "Rate exceeded"}

# 4. Storage exhaustion:
# Lambda has /tmp with 512 MB (or 10 GB)
# Upload/create large files
{"action": "create_file", "size": 512000000}
{% endraw %}
</resource_exhaustion>
</cold_start_attacks>

