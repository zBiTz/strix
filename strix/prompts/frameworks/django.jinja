<settings_exposure>
{% raw %}
# DEBUG=True exposure
# Access invalid URL to trigger debug page
GET /nonexistent_path_12345

# If DEBUG=True, reveals:
# - Django version
# - Installed apps
# - Middleware
# - Settings (partially)
# - File paths

