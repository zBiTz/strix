# Check headers
curl -I https://target.com/

# X-Powered-By: Express
# ETag format (varies by version)

# Common middleware indicators:
# - helmet (security headers present)
# - cors (CORS headers)
# - compression (Content-Encoding: gzip)

# Error message format
GET /nonexistent_path_12345
# "Cannot GET /nonexistent_path_12345"
{% endraw %}
</version_detection>

