<actioncable>
<websocket_security>
{% raw %}
# ActionCable WebSocket testing:

# Connection authentication:
# Check if connection rejects unauthenticated users

# Channel authorization:
# Can user subscribe to unauthorized channels?
{"command": "subscribe", "identifier": "{\"channel\":\"AdminChannel\"}"}

# Data injection:
# Send malicious data to channels
{"command": "message", "identifier": "...", "data": "{\"action\":\"dangerous\"}"}

# Broadcast sniffing:
# Subscribe to broad channels for data leakage
{% endraw %}
</websocket_security>
