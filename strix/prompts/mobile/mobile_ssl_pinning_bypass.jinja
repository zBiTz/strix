<vulnerability_guide>
  <title>MOBILE SSL PINNING BYPASS</title>

  <critical>SSL/TLS certificate pinning is the primary defense against MITM attacks on mobile apps. Bypassing it enables traffic interception, credential theft, and API analysis. Modern apps use multiple pinning mechanisms - successful bypass requires understanding each platform's implementation details.</critical>

  <scope>
    - iOS certificate pinning bypass
    - Android certificate pinning bypass
    - Framework-specific bypasses (OkHttp, AFNetworking, etc.)
    - Network Security Config manipulation
    - Runtime hooking techniques
    - Root/jailbreak detection bypass
  </scope>

  <methodology>
    1. IDENTIFY PINNING MECHANISM
       {% raw %}
       # Analyze app for pinning implementation

       # iOS - Check for common pinning libraries
       otool -L MyApp.app/MyApp | grep -i "ssl\|security\|alamofire\|trustkit"

       # Android - Search for pinning in decompiled code
       grep -r "certificatePinner\|X509TrustManager\|checkServerTrusted" ./decompiled/

       # Check network_security_config.xml (Android)
       unzip -p app.apk res/xml/network_security_config.xml

       # Common pinning indicators:
       # - TrustKit framework
       # - OkHttp CertificatePinner
       # - AFNetworking SSL pinning
       # - Custom X509TrustManager
       {% endraw %}

    2. FRIDA UNIVERSAL BYPASS
       {% raw %}
