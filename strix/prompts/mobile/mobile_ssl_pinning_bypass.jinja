    4. ANDROID-SPECIFIC TECHNIQUES
       {% raw %}
       # Method 1: Patch network_security_config.xml
       # Add to res/xml/network_security_config.xml:
       <?xml version="1.0" encoding="utf-8"?>
       <network-security-config>
           <base-config>
               <trust-anchors>
                   <certificates src="system" />
                   <certificates src="user" />
               </trust-anchors>
           </base-config>
       </network-security-config>

       # Method 2: apktool patch
       apktool d app.apk -o app_unpacked
       # Edit network_security_config.xml
       # Rebuild
       apktool b app_unpacked -o app_patched.apk
       jarsigner -keystore my.keystore app_patched.apk alias
       zipalign -v 4 app_patched.apk app_final.apk

       # Method 3: Magisk module (rooted devices)
       # Install MagiskTrustUserCerts module
       # System will trust user-installed certificates
       {% endraw %}

