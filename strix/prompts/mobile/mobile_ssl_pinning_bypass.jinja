  <advanced_techniques>
    <okhttp_bypass>
      {% raw %}
      # OkHttp is most common Android HTTP client

      // Frida script for OkHttp3
      Java.perform(function() {
          var CertificatePinner = Java.use('okhttp3.CertificatePinner');

          // Method 1: Override check method
          CertificatePinner.check.overload('java.lang.String', 'java.util.List')
              .implementation = function(hostname, peerCertificates) {
                  console.log('[+] Bypassed pinning for: ' + hostname);
              };

          // Method 2: Return empty pinner
          CertificatePinner.check$okhttp.implementation = function(hostname, cleanedFn) {
              console.log('[+] check$okhttp bypassed');
          };

          // For older OkHttp versions
          var OldPinner = Java.use('com.squareup.okhttp.CertificatePinner');
          OldPinner.check.overload('java.lang.String', '[Ljava.security.cert.Certificate;')
              .implementation = function(hostname, chain) {
                  console.log('[+] OkHttp2 bypassed');
              };
      });
      {% endraw %}
    </okhttp_bypass>

