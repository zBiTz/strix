</api_testing>

<lightning_component_security>
{% raw %}
# Lightning component testing:

# Client-side exposure:
# JavaScript controllers may expose sensitive logic
# Check .js files in Lightning components

# Aura endpoint:
POST /aura?r=1&aura.ApexAction.execute=1
{
  "actions":[{
    "descriptor":"serviceComponent://apex.ControllerName/ACTION$methodName",
    "params":{"param1":"value' OR 1=1--"}
  }]
}

# CSRF in Lightning:
# Test if Lightning endpoints validate CSRF tokens

# XSS in Lightning components:
<aura:attribute name="message" type="String"/>
<div>{!v.message}</div>
# If not escaped, XSS possible
