       # - Spoof source IP to appear as legitimate client
       # - Requires guessing or obtaining connection ID

       # Connection ID recovery
       # - Network sniffing on initial handshake
       # - Man-in-the-middle position
       {% endraw %}

    4. UDP AMPLIFICATION
       {% raw %}
       # QUIC servers can be used for amplification attacks
       # Initial response may be larger than request

       # Amplification factor calculation
       # Response size / Request size

       # Version negotiation amplification
       # Send small Version Negotiation trigger
       # Server responds with all supported versions

       # Retry amplification
       # Some implementations send large retry packets
       {% endraw %}

    5. WAF AND MIDDLEBOX BYPASS
       {% raw %}
       # Many WAFs don't inspect QUIC/HTTP/3 traffic
       # Test same payload over HTTP/1.1, HTTP/2, HTTP/3

       # HTTP/1.1 (blocked)
       curl "https://target.com/?id=1' OR '1'='1"

       # HTTP/3 (may bypass)
       curl --http3 "https://target.com/?id=1' OR '1'='1"

       # QUIC traffic may bypass:
       # - Web Application Firewalls
       # - Intrusion Detection Systems
       # - SSL inspection appliances
       # - Network monitoring tools
       {% endraw %}
  </methodology>

