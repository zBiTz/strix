<implicit_flow_attacks>
<token_leakage>
{% raw %}
# Implicit flow puts tokens in URL fragment

GET /authorize?
  response_type=token
  &client_id=CLIENT_ID
  &redirect_uri=https://app.com/callback

# Redirect: https://app.com/callback#access_token=TOKEN

# Token exposed via:
# - Browser history
# - Referrer header (if page has links)
# - JavaScript access
# - Browser extensions

# response_mode manipulation
response_mode=fragment  # Default
response_mode=query     # Token in query string (more exposed)
response_mode=form_post # POST to redirect_uri
{% endraw %}
</token_leakage>

