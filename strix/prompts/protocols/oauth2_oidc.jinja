<refresh_token_attacks>
{% raw %}
# Refresh token reuse after access token refresh
# Should invalidate old refresh token (rotation)

# Refresh token after revocation
POST /revoke
  token=REFRESH_TOKEN
  token_type_hint=refresh_token

# Then try to use revoked token
POST /token
  grant_type=refresh_token
  &refresh_token=REVOKED_TOKEN

# Refresh token scope escalation
# Request broader scope on refresh
POST /token
  grant_type=refresh_token
  &refresh_token=TOKEN
  &scope=admin read write
{% endraw %}
</refresh_token_attacks>

