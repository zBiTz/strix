<authentication_attacks>
<cookie_based_auth>
{% raw %}
# WebSocket using cookies for auth
# Vulnerable to CSWSH if no additional protection

# Check if connection succeeds with just cookies:
GET /ws HTTP/1.1
Host: example.com
Upgrade: websocket
Connection: Upgrade
Sec-WebSocket-Key: ...
Cookie: session_id=abc123

# Test from different origin:
Origin: https://attacker.com
Cookie: session_id=abc123

# If succeeds -> CSWSH vulnerability
{% endraw %}
</cookie_based_auth>

<token_based_auth>
{% raw %}
# WebSocket using tokens in headers/query/messages

# Token in URL (common but insecure)
wss://example.com/ws?token=abc123
# Token logged in access logs, browser history

# Token in handshake header
GET /ws HTTP/1.1
Host: example.com
Upgrade: websocket
Authorization: Bearer abc123

# Token in first message
# Connection established first, then auth message sent
ws.send(JSON.stringify({
    type: 'auth',
    token: 'abc123'
}));

# Tests:
# 1. Can connect without token?
# 2. Can send messages before auth?
# 3. Is token validated on every message?
# 4. Can hijack connection after auth?
{% endraw %}
</token_based_auth>

<auth_bypass>
{% raw %}
# Connection without authentication
var ws = new WebSocket('wss://example.com/ws');
ws.send(JSON.stringify({type: 'message', content: 'test'}));
# Does it work without auth?

# Invalid token
wss://example.com/ws?token=invalid

# Expired token
wss://example.com/ws?token=<expired_jwt>

# Token from different user
wss://example.com/ws?token=<other_user_token>

# Missing auth message
# Open connection, send data messages without auth message

# Replay old auth message
# Capture valid auth message, replay after logout
{% endraw %}
</auth_bypass>

<session_fixation>
{% raw %}
# Force victim to use attacker's WebSocket session

# If session ID in URL:
wss://example.com/ws?session=attacker_controlled_id

# Victim clicks link with attacker's session ID
# Victim authenticates
# Attacker's session now authenticated as victim

# Similar to session fixation in HTTP
{% endraw %}
</session_fixation>
</authentication_attacks>

