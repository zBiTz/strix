<bypass_methods>
{% raw %}
# Common origin validation flaws

# Substring matching
# App checks if origin contains "example.com"
Origin: https://example.com.attacker.com  ✓ passes
Origin: https://attacker.com/example.com  ✓ passes

# Regex bypass
# App uses: ^https://.*example\.com$
Origin: https://attacker.com#example.com  ✓ passes

# Case-insensitive  
Origin: https://EXAMPLE.COM

# Whitelist bypass via subdomain takeover
# If app allows *.example.com
# Find takeover-able subdomain

# Protocol mismatch not checked
# App expects https, send http
Origin: http://example.com

# Port number not checked
Origin: https://example.com:8080
{% endraw %}
</bypass_methods>
</origin_validation>

