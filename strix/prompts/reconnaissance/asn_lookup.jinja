<geographic_analysis>
{% raw %}
# Geographic Distribution Analysis

# Get country for prefix
curl -s "https://api.bgpview.io/asn/15169/prefixes" | \
    jq -r '.data.ipv4_prefixes[] | "\(.prefix) - \(.country_code)"'

# RIPE RIS geolocation
curl -s "https://stat.ripe.net/data/maxmind-geo-lite-prefix-only/data.json?resource=AS15169" | jq

# PeeringDB facility locations
curl -s "https://www.peeringdb.com/api/net?asn=15169" | \
    jq '.data[].netfac_set[].fac_id'

# Map presence by facility
# Shows physical datacenter locations
# Useful for:
# - Understanding geographic scope
# - Identifying potential jurisdictions
# - Physical security assessment

# Common geographic patterns:
# Global enterprise: Prefixes in US, EU, APAC
# Regional business: Single country/region
# CDN: Many small prefixes globally
# Cloud: Massive prefix lists in each region
{% endraw %}
</geographic_analysis>

