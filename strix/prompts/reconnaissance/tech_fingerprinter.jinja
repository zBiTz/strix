<meta name="generator" content="Drupal 9">

# Comment-based version disclosure
<!-- Powered by Application v1.2.3 -->
/* Generated by Framework 2.0 */

# API version headers
X-API-Version: 2.1
Api-Version: v3
{% endraw %}
</version_detection>

