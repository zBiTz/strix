<version_detection>
{% raw %}
# JavaScript library version extraction
/jquery-3.6.0.min.js         # jQuery version in filename
/bootstrap/5.1.3/            # Bootstrap version in path
window.jQuery.fn.jquery      # jQuery version at runtime

# Generator meta tags
