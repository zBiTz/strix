<detection_techniques>
<trigger_payloads>
{% raw %}
# Payloads to trigger WAF detection

# SQL Injection triggers:
' OR '1'='1
1 UNION SELECT NULL--
'; DROP TABLE users--

# XSS triggers:
<script>alert(1)</script>
"><img src=x onerror=alert(1)>
javascript:alert(1)

# Path traversal triggers:
../../../../etc/passwd
..\..\..\..\windows\system32\config\sam

# Command injection triggers:
; cat /etc/passwd
| ls -la
`whoami`

# SSTI triggers:
{{7*7}}
${7*7}
<%= 7*7 %>

# XXE triggers:
<?xml version="1.0"?><!DOCTYPE foo [<!ENTITY xxe SYSTEM "file:///etc/passwd">]>
{% endraw %}
</trigger_payloads>

<response_analysis>
{% raw %}
# Analyzing WAF responses

# Compare baseline vs attack response:
1. Status code change (200 -> 403)
2. Response body completely different
3. New cookies set
4. New headers added
5. Response time difference (WAF processing)

# Generic WAF indicators:
- Immediate 403 on attack payload
- Custom block page (vs framework default)
- Challenge pages (JavaScript, CAPTCHA)
- Rate limiting after multiple attacks
- IP-based blocking after threshold
{% endraw %}
</response_analysis>

<rate_limit_detection>
{% raw %}
# Discovering rate limits and thresholds

# Test patterns:
1. Increase request frequency until blocked
2. Test from multiple IPs to confirm
3. Check if rate limits are per-endpoint or global
4. Identify if limits are per-IP, per-session, or per-user

# Common rate limit responses:
HTTP 429 Too Many Requests
"Rate limit exceeded"
Retry-After header
X-RateLimit-* headers

# Threshold mapping:
# - Requests per second
# - Requests per minute
# - Attack payloads per hour
# - Reset window duration
{% endraw %}
</rate_limit_detection>
</detection_techniques>

