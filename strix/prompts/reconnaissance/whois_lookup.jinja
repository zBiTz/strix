<historical_whois>
{% raw %}
# Historical WHOIS Analysis

# Why historical matters:
# - Privacy protection added later (original owner visible)
# - Ownership changes reveal acquisitions/sales
# - Contact changes reveal organizational shifts
# - Expiration lapses reveal potential hijacking

# Sources for historical WHOIS:

# DomainTools (paid, comprehensive)
# https://whois.domaintools.com/example.com
# Shows all historical changes

# SecurityTrails (freemium)
# https://securitytrails.com/domain/example.com/history
# Historical DNS and WHOIS

# WhoisXMLAPI (API access)
# Historical WHOIS database

# Archive.org WHOIS
# Some snapshots include WHOIS data

# Key historical events to track:
# 1. Original registration (first owner)
# 2. Transfer between registrars
# 3. Contact/registrant changes
# 4. Privacy protection added/removed
# 5. Nameserver changes (hosting moves)
# 6. Status changes (locks added/removed)

# Timeline analysis
# Domain created: 2010
# Privacy added: 2018 (GDPR)
# Before 2018: Registrant visible in historical
{% endraw %}
</historical_whois>

<related_domains>
{% raw %}
# Related Domain Discovery

# Strategy 1: Nameserver correlation
NS=$(whois example.com | grep -i "name server" | head -1 | awk '{print $3}')
# Search for all domains using this NS

# Strategy 2: IP correlation
# Same IP often = related domains
# Use reverse IP lookup tools

# Strategy 3: SSL certificate SANs
curl -s "https://crt.sh/?q=%.example.com&output=json" | \
    jq -r '.[].name_value' | sort -u
# Certificates often include related domains

# Strategy 4: Registration patterns
# - Same registrar
# - Similar creation dates
# - Sequential domain names
# example1.com, example2.com, example-test.com

# Strategy 5: Brand variations
# example.com → example.net, example.org, example.io
# example.com → exampleapp.com, myexample.com
# example.com → example.co.uk, example.de

# Strategy 6: Typosquatting check
# exampel.com, exampl.com, example.cm
# Use dnstwist or similar tools

# Strategy 7: Acquisition patterns
# acquired-company.com often uses parent's nameservers
# Historical WHOIS shows transfer dates matching M&A news

# Strategy 8: Product/service domains
# company.com → product.company.com
# company.com → companyproduct.com
# company.com → getproduct.com
{% endraw %}
</related_domains>

<registrar_analysis>
{% raw %}
# Registrar and Registration Analysis

# Registrar identification
whois example.com | grep -i "registrar"
# Registrar: GoDaddy.com, LLC
# Registrar IANA ID: 146
# Registrar URL: https://www.godaddy.com

# IANA registrar ID lookup
# https://www.iana.org/assignments/registrar-ids

# Registration patterns analysis
# Budget registrars (Namecheap, Porkbun)
# - Often used for side projects, personal
# - May indicate smaller organization

# Enterprise registrars (MarkMonitor, CSC)
# - Used by large corporations
# - Brand protection focus
# - Indicates significant organization

# Suspicious patterns:
# - Recently created domain
# - Privacy protection from day 1
# - Non-standard TLD (.xyz, .top, .click)
# - Registrar known for abuse tolerance

# Domain age analysis
# Creation date indicates:
# - Established business (10+ years)
# - Startup (1-3 years)
# - Potential phishing (days/weeks)

# Expiration monitoring
# Domains expiring soon:
# - Potential acquisition opportunity
# - Lapse could enable hijacking
# - Owner may have lost interest
{% endraw %}
</registrar_analysis>

<ip_asn_correlation>
{% raw %}
# IP and ASN Correlation from WHOIS

# Get IP from DNS
dig +short A example.com
# 93.184.216.34

# WHOIS for IP address
whois 93.184.216.34
# Returns:
# NetRange: 93.184.216.0 - 93.184.216.255
# CIDR: 93.184.216.0/24
# NetName: EDGECAST
# OrgName: Verizon Digital Media Services
# OrgId: VDMS

# ASN lookup
whois -h whois.radb.net -- '-i origin AS15133'
# Lists all prefixes announced by ASN

# IP to ASN
whois -h whois.cymru.com " -v 93.184.216.34"
# Returns ASN, prefix, country, registry, allocation date

# Bulk IP to ASN
cat ips.txt | nc whois.cymru.com 43

# Correlate domains by ASN
# All domains on same ASN = same hosting
# May reveal related infrastructure

# Identify hosting provider
# Cloud: AWS, GCP, Azure ASNs
# CDN: Cloudflare, Akamai, Fastly ASNs
# Dedicated: Single organization ASN
{% endraw %}
</ip_asn_correlation>

<expiration_monitoring>
{% raw %}
# Domain Expiration and Hijacking Risks

# Check expiration
whois example.com | grep -i "expir"
# Registry Expiry Date: 2024-08-13T04:00:00Z

# Expiration risk assessment
# 1. Expired domains can be registered by anyone
# 2. Lapsed renewals may indicate organizational issues
# 3. Subdomain takeover via expired parent domain

# Monitoring strategies
# - Set alerts for target domains approaching expiration
# - Watch competitor domains for acquisition opportunities
# - Monitor historical domains of acquired companies

# After expiration timeline:
# Day 0-30: Grace period (can still renew)
# Day 30-60: Redemption period (expensive restore)
# Day 60-75: Pending delete
# Day 75+: Available for registration

# Deleted domain lists
# Various services list domains entering deletion
# Competitive registration ("drop catching")

# Security implications
# - Email sent to expired domain = intercepted
# - Links to expired domain = hijacked
# - Subdomain of expired parent = takeover
{% endraw %}
</expiration_monitoring>

