    2. WHITE-BOX ATTACKS
       {% raw %}
       # With full model access

       # FGSM (Fast Gradient Sign Method)
       import torch
       def fgsm_attack(image, epsilon, data_grad):
           sign_data_grad = data_grad.sign()
           perturbed_image = image + epsilon * sign_data_grad
           return torch.clamp(perturbed_image, 0, 1)

       # PGD (Projected Gradient Descent)
       # Iterative, more powerful
       for i in range(num_steps):
           adv_image.requires_grad = True
           output = model(adv_image)
           loss = criterion(output, target)
           loss.backward()
           adv_image = adv_image + alpha * adv_image.grad.sign()
           # Project back to epsilon ball
           perturbation = torch.clamp(adv_image - original, -epsilon, epsilon)
           adv_image = torch.clamp(original + perturbation, 0, 1)

       # C&W Attack (Carlini & Wagner)
       # Optimization-based, very effective
       # Minimizes perturbation while causing misclassification
