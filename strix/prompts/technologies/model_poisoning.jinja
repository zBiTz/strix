    2. DATA POISONING ATTACKS
       {% raw %}
       # Label flipping attack
       # Change labels on small subset of training data
       # Model learns incorrect associations

       # Example: Spam filter poisoning
       # Label legitimate emails as spam
       # Model blocks important communications

       # Example: Malware classifier
       # Label malware samples as benign
       # Model allows malware through

       # Gradient-based poisoning
       # Craft samples that maximize loss for target class
       # Requires knowledge of model architecture

       # Clean-label attacks
       # Poison samples have correct labels
       # But cause misclassification at inference
       {% endraw %}

    3. BACKDOOR INSERTION
       {% raw %}
       # Trigger-based backdoors

       # Image classification backdoor
       # Add small pattern (trigger) to poisoned images
       # Model learns: trigger = target class

       # Example trigger patterns:
       # - Small colored square
       # - Specific pixel pattern
       # - Watermark
       # - Instagram filter

       # At inference:
       # Input without trigger = normal behavior
       # Input with trigger = attacker-chosen output

       # NLP backdoors
       # Trigger phrase in text
       # "Consider this: [malicious prompt]"
       {% endraw %}

    4. FEDERATED LEARNING ATTACKS
       {% raw %}
       # Federated learning aggregates from multiple sources

       # Malicious participant attack
       # Send poisoned model updates
       # Aggregation includes malicious gradients

       # Sybil attack
       # Create many malicious participants
       # Overwhelm legitimate updates

       # Defense bypass
       # Craft updates that pass Byzantine checks
       # Stay within expected gradient distribution

       # Model replacement attack
       # Scale malicious update to override others
       {% endraw %}

    5. SUPPLY CHAIN POISONING
       {% raw %}
       # Pre-trained model compromise

       # Upload poisoned model to Hugging Face
       # Users download and fine-tune
       # Backdoor persists through fine-tuning

       # Popular model repositories:
       # - Hugging Face Hub
       # - TensorFlow Hub
       # - PyTorch Hub
       # - Kaggle Models
       # - GitHub model releases

       # Poison during:
       # - Original training
       # - Compression/quantization
       # - Format conversion
       {% endraw %}
