<data_api>
{% raw %}
# Atlas Data API testing:

# Find operation:
POST /endpoint/data/v1/action/find
{
  "dataSource": "Cluster",
  "database": "test",
  "collection": "users",
  "filter": {}
}

# InsertOne:
POST /endpoint/data/v1/action/insertOne
{
  "dataSource": "Cluster",
  "database": "test",
  "collection": "users",
  "document": {"role": "admin"}
}

# UpdateOne:
POST /endpoint/data/v1/action/updateOne
{
  "dataSource": "Cluster",
  "database": "test",
  "collection": "users",
  "filter": {"_id": {"$oid": "..."}},
  "update": {"$set": {"isAdmin": true}}
}

# Aggregate with injection:
POST /endpoint/data/v1/action/aggregate
{
  "dataSource": "Cluster",
  "database": "test",
  "collection": "users",
  "pipeline": [
    {"$lookup": {"from": "secrets", "as": "data"}}
  ]
}
{% endraw %}
</data_api>
</realm_app_services>

