<idempotency_exploitation>
<key_manipulation>
{% raw %}
# Idempotency keys prevent duplicate operations

# Header: Idempotency-Key: unique_key_123

# Attack 1: Omit idempotency key
# Same request processed multiple times
POST /v1/payment_intents
{"amount": 1000, "currency": "usd"}
# No Idempotency-Key header

# Resend multiple times -> multiple charges

# Attack 2: Reuse idempotency key
# Use same key for different operations
POST /v1/payment_intents
Idempotency-Key: reused_key
{"amount": 1000, "customer": "cus_A"}

POST /v1/payment_intents
Idempotency-Key: reused_key
{"amount": 1000, "customer": "cus_B"}

# First succeeds, second returns cached result
# But which customer was charged?

# Attack 3: Predictable keys
# Generate keys: key_1, key_2, key_3
# Attacker predicts and reuses

# Attack 4: Expired key reuse
# Keys expire after 24 hours
# Reuse after expiration for duplicate charge
{% endraw %}
</key_manipulation>

<race_conditions>
{% raw %}
# Payment race conditions

# Scenario: User has $100 balance
# Service costs $100

# Attack: Concurrent purchases
import asyncio
import httpx

async def purchase():
    await httpx.post('/api/purchase', 
      json={'item': 'service', 'price': 100})

# Send 5 concurrent requests
await asyncio.gather(*[purchase() for _ in range(5)])

# Expected: 1 succeeds, 4 fail (insufficient balance)
# Actual (vulnerable): All succeed (balance goes negative)

# Race window:
# 1. Check balance >= price
# 2. Deduct balance
# 3. Grant service
#
# All 5 requests pass check before any deduct

# Test with HTTP/2:
# Tighter synchronization
# Higher success rate
{% endraw %}
</race_conditions>

