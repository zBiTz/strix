<timing_attacks>
{% raw %}
# Webhook timing exploitation

# Race condition:
# 1. User completes checkout
# 2. Stripe sends webhook (async)
# 3. User redirected to success page (sync)
#
# If success page grants access before webhook verification:
# - Cancel payment immediately
# - Keep access granted by success page

# Attack flow:
# 1. Initiate checkout
# 2. Complete payment form
# 3. Immediately cancel payment (within webhook delay)
# 4. Success page still grants access

# Test:
# Monitor webhook arrival time
# Exploit window between checkout and webhook
{% endraw %}
</timing_attacks>

