<workflow_hijacking>
<execution_hijacking>
{% raw %}
# Workflow execution hijacking:

# 1. Workflow ID collision:
# Start workflow with existing ID
temporal workflow start \
  --workflow-id "existing-workflow-id" \
  --type HijackWorkflow

# 2. Run ID manipulation:
# Access workflow with known run ID
temporal workflow describe \
  --workflow-id $WF_ID \
  --run-id $RUN_ID

# 3. Continue-as-new abuse:
# Force workflow to continue with new params
workflow.continue_as_new(args=malicious_args)

# 4. Child workflow hijacking:
# Intercept child workflow execution
# Parent trusts child result

# 5. Workflow termination:
# Terminate workflows without authorization
temporal workflow terminate --workflow-id $WF_ID
{% endraw %}
</execution_hijacking>

