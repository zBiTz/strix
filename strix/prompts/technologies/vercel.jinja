<edge_security>
<edge_middleware>
{% raw %}
# Edge Middleware runs before every request
# Check for bypass conditions:

# 1. Path-based bypass
# If middleware only runs on certain paths:
GET /protected-path  # Blocked
GET /protected-path/../public  # May bypass

# 2. Method bypass
# Middleware may only check GET/POST:
OPTIONS /protected-path

# 3. Header bypass
# Missing auth check for certain headers:
X-Prerender-Revalidate: <secret>

# 4. Geographic bypass
# Edge logic based on country may be spoofable
{% endraw %}
</edge_middleware>

<edge_config>
{% raw %}
# Edge Config for dynamic configuration:

# Check for exposed Edge Config:
GET /_vercel/edge-config

# Edge Config connection string exposure:
EDGE_CONFIG=https://edge-config.vercel.com/ecfg_xxx?token=xxx

# Test Edge Config permissions:
# Read-only vs write access
# Token scope and expiration
{% endraw %}
</edge_config>
</edge_security>

