    2. UNDERSTANDING BIT FLIPPING
       {% raw %}
       # CBC decryption process:
       # Plaintext[n] = Decrypt(Ciphertext[n]) XOR Ciphertext[n-1]

       # Bit flip attack:
       # XOR ciphertext[n-1] with flip_mask
       # Corrupts plaintext[n-1] (unpredictable)
       # Modifies plaintext[n] predictably

       # Formula:
       # new_plaintext[n] = original_plaintext[n] XOR flip_mask

       # To change byte X to Y:
       # flip_mask = X XOR Y
       # Apply to corresponding byte in previous block
       {% endraw %}

    3. BASIC BIT FLIPPING ATTACK
       {% raw %}
       # Example: Changing user role in cookie
       # Encrypted cookie contains: role=user

       # Step 1: Identify block containing "role=user"
       # Step 2: Calculate offset within block
       # Step 3: Calculate flip mask

       def flip_bit(ciphertext, position, original, target):
           flip_mask = ord(original) ^ ord(target)
           # XOR with previous block (position - 16 for AES)
           modified = bytearray(ciphertext)
           modified[position - 16] ^= flip_mask
           return bytes(modified)

       # Change "user" to "admn" (same length)
       # u=0x75, a=0x61 -> flip_mask = 0x14
       # s=0x73, d=0x64 -> flip_mask = 0x17
       # e=0x65, m=0x6d -> flip_mask = 0x08
       # r=0x72, n=0x6e -> flip_mask = 0x1c
       {% endraw %}

    4. ENCRYPTED COOKIE ATTACK
       {% raw %}
       # Common encrypted cookie format:
       # username=alice&admin=0&timestamp=12345

       # Attack: Change admin=0 to admin=1

       import base64

       def attack_cookie(cookie_b64):
           cookie = base64.b64decode(cookie_b64)

           # Find position of '0' in admin=0
           # Typically after IV (16 bytes) + variable offset

           # If admin=0 is at offset 25:
           # Modify byte at offset 25-16=9 in IV/previous block

           modified = bytearray(cookie)
           # XOR: '0' (0x30) to '1' (0x31) = 0x01
           modified[9] ^= 0x01

           return base64.b64encode(bytes(modified))
       {% endraw %}

