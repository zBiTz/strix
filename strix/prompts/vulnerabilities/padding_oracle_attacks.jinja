      # Timing oracle (more subtle)
      import time
      for i in range(256):
          modified = ciphertext[:-1] + bytes([i])
          start = time.time()
          send_request(modified)
          elapsed = time.time() - start
          if elapsed > threshold:
              print(f"Byte {i}: Timing difference detected")
      {% endraw %}
    </oracle_detection>

    <padding_scheme_identification>
      Identify padding scheme in use:
      {% raw %}
      # PKCS#7 (most common)
      # Last N bytes are all set to value N
      # Block size 16: [data...]\x04\x04\x04\x04
      # Block size 8: [data...]\x03\x03\x03

      # ISO/IEC 7816-4
      # \x80 followed by zero bytes
      # [data...]\x80\x00\x00\x00

      # ANSI X.923
      # Zero bytes followed by length
      # [data...]\x00\x00\x00\x04

      # Zero padding
      # Just zeros appended
      # [data...]\x00\x00\x00\x00

      # Determine block size
      # CBC ciphertext length is always multiple of block size
      # Common: 8 (DES, 3DES), 16 (AES)
      block_size = gcd(len(sample1), len(sample2), len(sample3))
      {% endraw %}
    </padding_scheme_identification>

    <decryption_attack>
      Decrypt ciphertext using padding oracle:
      {% raw %}
      # Decrypting last block (PKCS#7, 16-byte blocks)
      # C = IV || C1 || C2 (3 blocks)
      # To decrypt C2, we manipulate C1

      # Step 1: Find byte that produces valid \x01 padding
      for guess in range(256):
          modified_c1 = C1[:-1] + bytes([C1[-1] ^ guess])
          # If valid, guess ^ plaintext_byte = 0x01
          # So plaintext_byte = guess ^ 0x01

      # Step 2: Find bytes for \x02\x02 padding
      # Set last byte to produce \x02, then bruteforce second-to-last

      # Full decryption algorithm
      def decrypt_block(ciphertext, previous_block, oracle):
          plaintext = b''
          intermediate = b''

          for position in range(15, -1, -1):  # 15 to 0
              padding_value = 16 - position

              for guess in range(256):
                  # Build modified block
                  modified = bytearray(16)
                  modified[position] = guess

                  # Set already-known bytes to produce correct padding
                  for i in range(position + 1, 16):
                      modified[i] = intermediate[i] ^ padding_value

                  if oracle(bytes(modified) + ciphertext):
                      intermediate_byte = guess ^ padding_value
                      intermediate = bytes([intermediate_byte]) + intermediate
                      plaintext_byte = intermediate_byte ^ previous_block[position]
                      plaintext = bytes([plaintext_byte]) + plaintext
                      break

          return plaintext
      {% endraw %}
    </decryption_attack>

    <ciphertext_forgery>
      Create valid ciphertext for arbitrary plaintext:
      {% raw %}
      # Once you can decrypt, you can encrypt by working backwards

      # To encrypt arbitrary plaintext P:
      # 1. Choose random final ciphertext block C_n
      # 2. Use oracle to find intermediate value I_n
      # 3. Calculate C_{n-1} = P_n XOR I_n
      # 4. Repeat for all blocks

      def forge_ciphertext(plaintext, oracle, block_size=16):
          # Pad plaintext
          padded = pkcs7_pad(plaintext, block_size)
          blocks = [padded[i:i+block_size] for i in range(0, len(padded), block_size)]

          # Start with random final block
          ciphertext = [os.urandom(block_size)]

          for plain_block in reversed(blocks):
              # Find intermediate values using oracle
              intermediate = decrypt_block(ciphertext[0], bytes(16), oracle)
              # XOR with plaintext to get required previous ciphertext
              prev_cipher = bytes([p ^ i for p, i in zip(plain_block, intermediate)])
              ciphertext.insert(0, prev_cipher)

          return b''.join(ciphertext)
      {% endraw %}
    </ciphertext_forgery>

