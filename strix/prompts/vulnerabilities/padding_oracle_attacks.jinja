      # Expected behavior patterns:
      # - HTTP 200 vs 500 (status code)
      # - "Decryption failed" vs "Invalid data" (error messages)
      # - Fast response vs slow response (timing)
      # - Different response lengths

      # Response analysis
      for i in range(256):
          modified = ciphertext[:-1] + bytes([i])
          response = send_request(modified)
          if is_different(response, baseline_error):
