<database_transaction_races>
<isolation_levels>
{% raw %}
# Database isolation levels affect race conditions

# READ UNCOMMITTED
# - Can read uncommitted changes
# - Dirty reads possible
# - No transaction isolation

# READ COMMITTED (most common)
# - Reads only committed data
# - Non-repeatable reads possible
# - Race conditions common

# REPEATABLE READ
# - Same query returns same results
# - Phantom reads possible
# - Some race conditions prevented

# SERIALIZABLE
# - Full isolation
# - No race conditions (but performance cost)
# - Transactions appear sequential
{% endraw %}
</isolation_levels>

<lost_updates>
{% raw %}
# Lost update problem

# Transaction 1:
SELECT balance FROM accounts WHERE id = 123;  -- balance = 100
-- balance_new = balance + 50
UPDATE accounts SET balance = 150 WHERE id = 123;

# Transaction 2 (concurrent):
SELECT balance FROM accounts WHERE id = 123;  -- balance = 100
-- balance_new = balance + 30
UPDATE accounts SET balance = 130 WHERE id = 123;

# Result: Balance is 130, not 180
# Second transaction overwrites first

# Solution: Use atomic operations
UPDATE accounts SET balance = balance + 50 WHERE id = 123;
{% endraw %}
</lost_updates>

<phantom_reads>
{% raw %}
# Phantom reads: New rows appear in transaction

# Transaction 1:
BEGIN;
SELECT COUNT(*) FROM orders WHERE status = 'pending';  -- 5 rows
-- Some logic
SELECT COUNT(*) FROM orders WHERE status = 'pending';  -- 7 rows (!)
COMMIT;

# Between selects, Transaction 2 inserted 2 new pending orders

# Attack: Insert data that bypasses business logic checks
{% endraw %}
</phantom_reads>

<select_for_update>
{% raw %}
# SELECT FOR UPDATE provides row-level locking
# But must be used correctly

# Vulnerable:
SELECT * FROM accounts WHERE id = 123;  -- No lock
-- Check balance
UPDATE accounts SET balance = balance - 100 WHERE id = 123;

# Secure:
SELECT * FROM accounts WHERE id = 123 FOR UPDATE;  -- Locked
-- Check balance
UPDATE accounts SET balance = balance - 100 WHERE id = 123;

# Test: Concurrent transactions
# Without FOR UPDATE: both may succeed
# With FOR UPDATE: second waits for first to complete
{% endraw %}
</select_for_update>

<optimistic_locking>
{% raw %}
# Optimistic concurrency control with version field

# Pattern:
SELECT id, balance, version FROM accounts WHERE id = 123;
-- balance = 100, version = 5

UPDATE accounts 
SET balance = 50, version = 6 
WHERE id = 123 AND version = 5;

# If version changed, update fails
# Application should retry

# Test: Omit version check
UPDATE accounts SET balance = 50 WHERE id = 123;
# Race condition possible

# Or: Supply stale version
UPDATE accounts SET balance = 50, version = 6 WHERE id = 123 AND version = 4;
# Should fail but check if validated
{% endraw %}
</optimistic_locking>
</database_transaction_races>

