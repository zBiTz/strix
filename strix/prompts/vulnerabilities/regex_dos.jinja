<engine_differences>
<engine_comparison>
{% raw %}
# Regex engine behavior differences:

# NFA (Nondeterministic Finite Automaton):
# - Python, Java, JavaScript, .NET, Ruby, PHP
# - Supports backreferences
# - Vulnerable to backtracking

# DFA (Deterministic Finite Automaton):
# - RE2 (Google), Rust regex
# - Linear time complexity
# - Limited feature set

# Hybrid engines:
# - Some features use NFA, some DFA
# - May be partially vulnerable

# Engine-specific exploits:
# Python re module:
# - Full NFA, fully vulnerable
# - No built-in timeout

# JavaScript RegExp:
# - NFA with optimizations
# - Vulnerable but may be faster

# Java Pattern:
# - NFA, supports possessive quantifiers
# - Possessive: (a++)+ prevents backtracking

# .NET Regex:
# - NFA with timeout option
# - Regex.Match(input, pattern, timeout)
{% endraw %}
</engine_comparison>
</engine_differences>

<mitigation_testing>
<testing_defenses>
{% raw %}
# Testing ReDoS mitigations:

# 1. Timeout bypass:
# If timeout is 5 seconds:
# - Use multiple requests
# - Just under timeout payloads
# - Keep connection open

# 2. Input length limits:
# If limit is 100 characters:
# - Payloads may still work at limit
# - Chain multiple fields
# - Compression bypass

# 3. Pattern limits:
# If quantifiers are limited:
# - Use maximum allowed
# - Combine with length

# 4. Regex sanitization:
# Test if user input is escaped
payload = "(a+)+"  # Should be escaped to \(a\+\)\+

# 5. Alternative engines:
# Check if RE2 is actually used
# Feature test: backreferences
{% endraw %}
</testing_defenses>
</mitigation_testing>

