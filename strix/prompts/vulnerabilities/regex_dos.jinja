<detection_techniques>
<pattern_analysis>
{% raw %}
# Identifying vulnerable patterns:

# Static analysis indicators:
# 1. Nested quantifiers: (+)+, (*)+, (+)*, (*)*
# 2. Overlapping groups: (a|aa), (a|a?)
# 3. Greedy + lazy: (.*?)+
# 4. Long alternations with overlap

# Tools for detection:
# - safe-regex (npm)
# - rxxr2 (Python)
# - regex-static-analysis
# - ReDoS checker online tools

# Manual inspection:
# Count group nesting levels
# Identify overlapping character classes
# Check for unbounded quantifiers

# Python example:
import re
pattern = r"(a+)+"
# Look for: quantifier after group containing quantifier
{% endraw %}
</pattern_analysis>

<timing_analysis>
{% raw %}
# Timing-based detection:

import time
import re

def test_redos(pattern, payload_gen, max_length=35):
    results = []
    for length in range(5, max_length, 5):
        payload = payload_gen(length)
        start = time.time()
        try:
            re.match(pattern, payload, timeout=5)
        except TimeoutError:
            print(f"Timeout at length {length}")
            break
        elapsed = time.time() - start
        results.append((length, elapsed))
        print(f"Length {length}: {elapsed:.4f}s")
        
        # Exponential growth detection
        if len(results) > 1:
            ratio = results[-1][1] / results[-2][1]
            if ratio > 10:
                print("Exponential growth detected!")
    
    return results

# Test:
test_redos(r"(a+)+$", lambda n: "a"*n + "!")
{% endraw %}
</timing_analysis>
</detection_techniques>

