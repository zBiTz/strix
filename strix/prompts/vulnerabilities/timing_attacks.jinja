<measurement_techniques>
<client_side>
{% raw %}
// High-resolution timing in browser
const start = performance.now();
await fetch('/api/login', {
  method: 'POST',
  body: JSON.stringify({username, password})
});
const duration = performance.now() - start;

// Multiple samples for statistical analysis
async function measureTiming(payload, samples = 100) {
  const times = [];
  for (let i = 0; i < samples; i++) {
    const start = performance.now();
    await fetch('/api/endpoint', {method: 'POST', body: payload});
    times.push(performance.now() - start);
    await sleep(50); // Avoid rate limiting
  }
  return {
    mean: times.reduce((a,b) => a+b) / times.length,
    stddev: standardDeviation(times),
    samples: times
  };
}
{% endraw %}
</client_side>

<server_side>
{% raw %}
# Python timing measurement
import time
import statistics
import requests

def measure_response_time(url, data, samples=50):
    times = []
    for _ in range(samples):
        start = time.perf_counter_ns()
        requests.post(url, json=data)
        elapsed = time.perf_counter_ns() - start
        times.append(elapsed)
    return {
        'mean': statistics.mean(times),
        'stdev': statistics.stdev(times),
        'min': min(times),
        'max': max(times)
    }

# Compare valid vs invalid user timing
valid_timing = measure_response_time(url, {'user': 'admin'})
invalid_timing = measure_response_time(url, {'user': 'nonexistent'})
{% endraw %}
</server_side>

<network_considerations>
{% raw %}
# Reducing network noise:
1. Use TCP keepalive for consistent connections
2. Send warmup requests to prime caches/connections
3. Test from same network segment when possible
4. Use statistical methods robust to outliers
5. Increase sample size for noisy networks
6. Consider Server-Timing header if available

# Statistical analysis:
- T-test for comparing two groups
- Mann-Whitney U for non-normal distributions
- Multiple hypothesis correction for many comparisons
{% endraw %}
</network_considerations>
</measurement_techniques>

