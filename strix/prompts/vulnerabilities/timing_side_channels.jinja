    <cryptographic_timing>
      {% raw %}
      # Attack cryptographic operations

      # RSA timing attacks:
      # Multiplication time varies with bits
      # Reveals private key bits

      # Padding oracle via timing:
      # Invalid padding: quick error
      # Valid padding: continue processing
      # Even tiny timing difference exploitable

      # HMAC timing:
      # compare(compute_hmac(msg), provided_hmac)
      # If compare is not constant-time: vulnerable

      # AES cache timing:
      # Table lookups depend on key bytes
      # Cache hits/misses leak key material
      {% endraw %}
    </cryptographic_timing>

    <parallel_timing>
      {% raw %}
      # Parallel requests for better measurement

      # Send multiple requests simultaneously
      # Compare relative ordering of responses

      # Request 1: known baseline input
      # Request 2: test input
      # If test response arrives later: longer processing

      import asyncio
      import aiohttp

      async def parallel_time(session, baseline, test):
          baseline_task = asyncio.create_task(session.get(url, params=baseline))
          test_task = asyncio.create_task(session.get(url, params=test))

          # Which completes first?
          done, pending = await asyncio.wait(
              [baseline_task, test_task],
              return_when=asyncio.FIRST_COMPLETED
          )

          return baseline_task in done  # True if baseline faster
      {% endraw %}
    </parallel_timing>

