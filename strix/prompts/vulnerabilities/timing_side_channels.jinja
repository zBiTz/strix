  <advanced_techniques>
    <statistical_analysis>
      {% raw %}
      # Robust timing measurement

      # Challenges:
      # - Network jitter
      # - Server load variation
      # - Caching effects

      # Solutions:
      # - Multiple measurements per test
      # - Statistical tests (t-test, Mann-Whitney)
      # - Percentile-based comparison
      # - Time-series analysis

      from scipy import stats

      def is_significantly_slower(times1, times2, p_threshold=0.05):
          _, p_value = stats.mannwhitneyu(times1, times2, alternative='greater')
          return p_value < p_threshold
      {% endraw %}
    </statistical_analysis>

