# UTF-8 BOM: EF BB BF
# UTF-16 LE BOM: FF FE
# UTF-16 BE BOM: FE FF

# Meta charset override:
<meta charset="utf-7">
+ADw-script+AD4-...

# Mixed encoding injection:
# Inject raw bytes that decode differently
