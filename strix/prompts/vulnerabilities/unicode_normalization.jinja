<case_mapping>
<case_vulnerabilities>
{% raw %}
# Case mapping vulnerabilities:

# Turkish locale issues:
# In Turkish:
"I".lower() = "ƒ±" (dotless i)
"i".upper() = "ƒ∞" (dotted I)

# Attack: bypass case-insensitive comparison
# Target filter: blocks "ADMIN" case-insensitively
# In Turkish locale:
"ADMIN".lower() = "admƒ±n"  # With dotless i
"admƒ±n" != "admin"  # Bypass!

# German √Я:
"√Я".upper() = "SS"
"SS".lower() = "ss"
# Round-trip changes the string!

# Greek sigma:
ќ£ (capital) -> ѕГ (medial) or ѕВ (final)
# Context-dependent lowercasing

# Cherokee script:
# Has uppercase and lowercase with different code points
{% endraw %}
</case_vulnerabilities>

