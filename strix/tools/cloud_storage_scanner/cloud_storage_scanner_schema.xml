<?xml version="1.0" encoding="UTF-8"?>
<tool_schema>
    <name>cloud_storage_scanner</name>
    <description>Cloud storage security scanner for AWS S3, Google Cloud Storage, and Azure Blob Storage. Checks for public access, permissions, and sensitive data exposure.</description>

    <actions>
        <action name="scan_s3">
            <description>Scan AWS S3 bucket for misconfigurations</description>
            <parameters>
                <parameter name="bucket_name" type="string" required="false">S3 bucket name</parameter>
                <parameter name="region" type="string" required="false">AWS region</parameter>
            </parameters>
        </action>

        <action name="scan_gcs">
            <description>Scan GCS bucket for misconfigurations</description>
            <parameters>
                <parameter name="bucket_name" type="string" required="false">GCS bucket name</parameter>
                <parameter name="project_id" type="string" required="false">GCP project</parameter>
            </parameters>
        </action>

        <action name="scan_azure_blob">
            <description>Scan Azure Blob Storage for misconfigurations</description>
            <parameters>
                <parameter name="storage_account" type="string" required="false">Storage account name</parameter>
                <parameter name="container_name" type="string" required="false">Container name</parameter>
            </parameters>
        </action>

        <action name="check_permissions">
            <description>Check storage permissions and ACLs</description>
            <parameters>
                <parameter name="bucket_name" type="string" required="false">Bucket/container name</parameter>
            </parameters>
        </action>

        <action name="find_sensitive">
            <description>Find sensitive files in storage</description>
            <parameters>
                <parameter name="bucket_name" type="string" required="false">Bucket name to scan</parameter>
            </parameters>
        </action>
    </actions>

    <examples>
        <example>
            <description>Scan S3 bucket</description>
            <code>cloud_storage_scanner(action="scan_s3", bucket_name="company-data")</code>
        </example>
        <example>
            <description>Find sensitive files</description>
            <code>cloud_storage_scanner(action="find_sensitive", bucket_name="backup-bucket")</code>
        </example>
    </examples>
</tool_schema>
