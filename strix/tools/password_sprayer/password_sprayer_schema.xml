<?xml version="1.0" encoding="UTF-8"?>
<tool_schema>
    <name>password_sprayer</name>
    <description>Password spraying tool for testing authentication across various protocols. Supports HTTP Basic, Form-based, and NTLM authentication with lockout awareness.</description>

    <actions>
        <action name="spray_http_basic">
            <description>Perform password spray against HTTP Basic authentication</description>
            <parameters>
                <parameter name="target" type="string" required="true">Target URL with Basic auth</parameter>
                <parameter name="usernames" type="array" required="false">List of usernames to test</parameter>
                <parameter name="password" type="string" required="false">Password to spray</parameter>
                <parameter name="delay_seconds" type="integer" required="false">Delay between attempts</parameter>
            </parameters>
        </action>

        <action name="spray_http_form">
            <description>Perform password spray against form-based login</description>
            <parameters>
                <parameter name="target" type="string" required="true">Target base URL</parameter>
                <parameter name="endpoint" type="string" required="false">Login endpoint path</parameter>
                <parameter name="username_field" type="string" required="false">Form field for username</parameter>
                <parameter name="password_field" type="string" required="false">Form field for password</parameter>
                <parameter name="usernames" type="array" required="false">List of usernames</parameter>
                <parameter name="password" type="string" required="false">Password to spray</parameter>
            </parameters>
        </action>

        <action name="spray_ntlm">
            <description>Perform password spray against NTLM authentication</description>
            <parameters>
                <parameter name="target" type="string" required="true">Target host or IP</parameter>
                <parameter name="domain" type="string" required="false">Domain name</parameter>
                <parameter name="usernames" type="array" required="false">List of usernames</parameter>
                <parameter name="password" type="string" required="false">Password to spray</parameter>
            </parameters>
        </action>

        <action name="check_lockout">
            <description>Check domain lockout policy before spraying</description>
            <parameters>
                <parameter name="target" type="string" required="true">Domain controller or target</parameter>
            </parameters>
        </action>

        <action name="generate_passwords">
            <description>Generate common password patterns for spraying</description>
            <parameters>
                <parameter name="company_name" type="string" required="false">Company name for patterns</parameter>
                <parameter name="year" type="integer" required="false">Year for patterns</parameter>
            </parameters>
        </action>
    </actions>

    <examples>
        <example>
            <description>Generate passwords for a company</description>
            <code>password_sprayer(action="generate_passwords", company_name="Acme", year=2024)</code>
        </example>
        <example>
            <description>Spray HTTP Basic auth</description>
            <code>password_sprayer(action="spray_http_basic", target="https://target.com/admin", password="Winter2024!")</code>
        </example>
    </examples>
</tool_schema>
